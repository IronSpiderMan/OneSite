import React, { useEffect, useState, useRef } from 'react';
import { useParams, useNavigate, useSearchParams } from 'react-router-dom';
import { ArrowLeft, Loader2, Save, Pencil, X } from 'lucide-react';
import { useTranslation } from 'react-i18next';
import { toast } from 'sonner';
import { use{{ model.name }}Store } from '../../stores/use{{ model.name }}Store';
import { Button } from '../../components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '../../components/ui/card';
import { Badge } from '../../components/ui/badge';
import { Label } from '../../components/ui/label';
import { formatDateTime, formatTime, getUserTimeZone } from '../../lib/datetime';
import { Separator } from '../../components/ui/separator';
import { FileUpload } from '../../components/ui/file-upload';
import { Switch } from '../../components/ui/switch';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '../../components/ui/select';
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from '../../components/ui/table';
{% if model.page_edit %}
import { useForm, Controller } from 'react-hook-form';
import { Input } from '../../components/ui/input';
import { JsonInput } from '../../components/ui/json-input';
import { JsonModelEditor, JsonModelArrayEditor } from '../../components/ui/json-model-editor';
import { ImageUpload } from '../../components/ui/image-upload';
import { TimePicker } from '../../components/ui/time-picker';
import { SearchableSelect } from '../../components/ui/searchable-select';
{% for fk in model.foreign_keys %}
import { get{{ fk.target_model }}s } from '../../services/{{ fk.target_service }}';
{% endfor %}
{% endif %}
{% for fk in model.foreign_keys %}
import { get{{ fk.target_model }} } from '../../services/{{ fk.target_service }}';
{% endfor %}
{% if model.actions %}
import { 
    {% for action_name, action_config in model.actions.items() %}
    perform{{ model.name }}{{ action_name.capitalize() }}{% if not loop.last %}, {% endif %}
    {% endfor %}
} from '../../services/{{ model.module_name }}';
{% endif %}
{% if model.m2m_fields %}
{% for m2m in model.m2m_fields %}
import { get{{ model.name }}{{ m2m.target_model }}s } from '../../services/{{ model.module_name }}';
{% endfor %}
{% endif %}
{% if model.reverse_m2m %}
{% for rel in model.reverse_m2m %}
{% if rel.display %}
import { get{{ model.name }}{{ rel.source_model }}s } from '../../services/{{ model.module_name }}';
{% endif %}
{% endfor %}
{% endif %}
{% if model.reverse_foreign_keys %}
{% for rfk in model.reverse_foreign_keys %}
{% if rfk.display %}
import { get{{ rfk.source_model }}s } from '../../services/{{ rfk.source_service }}';
{% endif %}
{% endfor %}
{% endif %}
{% if model.reverse_timeseries %}
{% for ts in model.reverse_timeseries %}
import { get{{ ts.model_name }}Realtime, get{{ ts.model_name }}History } from '../../services/{{ ts.module_name }}';
{% endfor %}
{% if model.reverse_timeseries %}
import { LineChart, Line, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer } from 'recharts';
{% endif %}
{% endif %}

const {{ model.name }}DetailPage: React.FC = () => {
    const { t } = useTranslation();
    const timeZone = getUserTimeZone();
    const { id } = useParams<{ id: string }>();
    const [searchParams] = useSearchParams();
    const navigate = useNavigate();
    const { fetchItem, currentItem, loading{% if model.page_edit %}, updateItem{% endif %} } = use{{ model.name }}Store();
    const userRole = (localStorage.getItem('user_role') || 'user') as 'user' | 'admin' | 'developer';
    const rolePermissions: Record<string, string> = {{ model.role_permissions | tojson }};
    const userPerms = rolePermissions[userRole] || '';
    const hasPermission = (perm: 'r' | 'c' | 'u' | 'd') => userPerms.includes(perm);

    // Field-level role-based permissions (Layer 2)
    const fieldRolePerms: Record<string, Record<string, string>> = {
    {% for field in model.fields %}
    {% if field.role_permissions %}
      "{{ field.name }}": {{ field.role_permissions | tojson }},
    {% endif %}
    {% endfor %}
    };
    const hasFieldPerm = (fieldName: string, perm: 'c' | 'r' | 'u') => {
      const fp = fieldRolePerms[fieldName];
      if (!fp) return true;
      return (fp[userRole] || '').includes(perm);
    };
    
    // State to store resolved foreign key data
    {% for fk in model.foreign_keys %}
    const [{{ fk.target_service }}Data, set{{ fk.target_model }}Data] = useState<any>(null);
    {% endfor %}

    // State for M2M data
    {% if model.m2m_fields %}
    {% for m2m in model.m2m_fields %}
    const [{{ m2m.name }}Data, set{{ m2m.target_model }}Data] = useState<any[]>([]);
    const [{{ m2m.name }}Total, set{{ m2m.target_model }}Total] = useState(0);
    const [{{ m2m.name }}Page, set{{ m2m.target_model }}Page] = useState(1);
    const [{{ m2m.name }}Loading, set{{ m2m.target_model }}Loading] = useState(false);
    {% endfor %}
    {% endif %}

    // State for Reverse M2M data
    {% if model.reverse_m2m %}
    {% for rel in model.reverse_m2m %}
    {% if rel.display %}
    const [{{ rel.name }}Data, set{{ rel.name|replace('_', ' ')|title|replace(' ', '') }}Data] = useState<any[]>([]);
    const [{{ rel.name }}Total, set{{ rel.name|replace('_', ' ')|title|replace(' ', '') }}Total] = useState(0);
    const [{{ rel.name }}Page, set{{ rel.name|replace('_', ' ')|title|replace(' ', '') }}Page] = useState(1);
    const [{{ rel.name }}Loading, set{{ rel.name|replace('_', ' ')|title|replace(' ', '') }}Loading] = useState(false);
    {% endif %}
    {% endfor %}
    {% endif %}

    // State for Reverse FK data (One-to-Many)
    {% if model.reverse_foreign_keys %}
    {% for rfk in model.reverse_foreign_keys %}
    {% if rfk.display %}
    const [{{ rfk.name }}Data, set{{ rfk.source_model }}Data] = useState<any[]>([]);
    const [{{ rfk.name }}Total, set{{ rfk.source_model }}Total] = useState(0);
    const [{{ rfk.name }}Page, set{{ rfk.source_model }}Page] = useState(1);
    const [{{ rfk.name }}Loading, set{{ rfk.source_model }}Loading] = useState(false);
    {% endif %}
    {% endfor %}
    {% endif %}

    {% if model.reverse_timeseries %}
    {% for ts in model.reverse_timeseries %}
    const [{{ ts.model_name }}Realtime, set{{ ts.model_name }}Realtime] = useState<any[]>([]);
    const [{{ ts.model_name }}Properties, set{{ ts.model_name }}Properties] = useState<Record<string, any>>({});
    const [{{ ts.model_name }}History, set{{ ts.model_name }}History] = useState<any[]>([]);
    const [{{ ts.model_name }}HistoryLoading, set{{ ts.model_name }}HistoryLoading] = useState(false);
    const [tsHistoryAutoRefresh, setTsHistoryAutoRefresh] = useState(false);
    const [tsHistoryLastRefreshed, setTsHistoryLastRefreshed] = useState<Date | null>(null);
    const [{{ ts.model_name }}SelectedMetrics, set{{ ts.model_name }}SelectedMetrics] = useState<string[]>([]);
    const [{{ ts.model_name }}TimeRange, set{{ ts.model_name }}TimeRange] = useState('1h');
    {% endfor %}
    const [tsAutoRefresh, setTsAutoRefresh] = useState(false);
    {% endif %}

    {% if model.page_edit %}
    const [isEditing, setIsEditing] = useState(false);
    const { register, handleSubmit: handleEditSubmit, reset, setValue: setEditValue, control: editControl } = useForm();

    {% for field in model.fields %}
    {% if field.fk_info %}
    const [edit{{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels, setEdit{{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels] = useState<Record<string, string>>({});
    {% endif %}
    {% endfor %}

    const onEditSave = async (values: any) => {
      try {
        await updateItem(currentItem!.id, values);
        toast.success(t('toast.update_success', 'Updated'));
        setIsEditing(false);
        fetchItem(currentItem!.id);
      } catch (error) {
        toast.error(t('toast.save_failed', 'Save failed'));
        console.error(error);
      }
    };

    const startEditing = () => {
      if (!currentItem) return;
      const item = currentItem;
      {% for field in model.fields %}
      {% if 'r' in field.permissions %}
      setEditValue('{{ field.name }}', item.{{ field.name }});
      {% endif %}
      {% endfor %}
      {% for field in model.fields %}
      {% if field.fk_info %}
      if (item.{{ field.name }}) {
        get{{ field.fk_info.target_model }}(item.{{ field.name }}).then((fkItem: any) => {
          if (fkItem) {
            setEdit{{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels({ [String(fkItem.id)]: fkItem.{{ field.fk_info.label_field }} || String(fkItem.id) });
          }
        });
      }
      {% endif %}
      {% endfor %}
      setIsEditing(true);
    };

    // Auto-enter edit mode when navigated from list page edit button
    const hasAutoEdited = useRef(false);
    useEffect(() => {
        if (currentItem && !hasAutoEdited.current && searchParams.get('edit') === 'true' && hasPermission('u')) {
            hasAutoEdited.current = true;
            startEditing();
        }
    }, [currentItem, searchParams]);
    {% endif %}

    {% if model.refresh_interval %}
    const [autoRefresh, setAutoRefresh] = useState(true);
    const [refreshInterval, setRefreshInterval] = useState({{ model.refresh_interval }});

    useEffect(() => {
        let interval: ReturnType<typeof setInterval>;
        if (autoRefresh && id) {
            interval = setInterval(() => {
                const itemId = parseInt(id);
                fetchItem(itemId);
            }, refreshInterval);
        }
        return () => clearInterval(interval);
    }, [autoRefresh, refreshInterval, id, fetchItem]);
    {% endif %}

    useEffect(() => {
        if (id) {
            const itemId = parseInt(id);
            fetchItem(itemId).then((item) => {
                if (item) {
                    // Fetch FK data
                    {% for fk in model.foreign_keys %}
                    if (item.{{ fk.name.replace('_id', '') }}_id) {
                        get{{ fk.target_model }}(item.{{ fk.name.replace('_id', '') }}_id).then(res => {
                             if (res) {
                                 set{{ fk.target_model }}Data(res);
                             }
                        });
                    }
                    {% endfor %}
                }
            });
            
            // Fetch M2M data
            {% if model.m2m_fields %}
            {% for m2m in model.m2m_fields %}
            fetch{{ m2m.target_model }}s(itemId, 1);
            {% endfor %}
            {% endif %}

            // Fetch Reverse M2M data
            {% if model.reverse_m2m %}
            {% for rel in model.reverse_m2m %}
            {% if rel.display %}
            fetch{{ model.name }}{{ rel.source_model }}s(itemId, 1);
            {% endif %}
            {% endfor %}
            {% endif %}

            // Fetch Reverse FK data
            {% if model.reverse_foreign_keys %}
            {% for rfk in model.reverse_foreign_keys %}
            {% if rfk.display %}
            fetch{{ rfk.source_model }}s(itemId, 1);
            {% endif %}
            {% endfor %}
            {% endif %}

            // Fetch Timeseries realtime data
            {% if model.reverse_timeseries %}
            {% for ts in model.reverse_timeseries %}
            fetch{{ ts.model_name }}Realtime(itemId);
            {% endfor %}
            {% endif %}

            // Fetch Timeseries history data
            {% if model.reverse_timeseries %}
            {% for ts in model.reverse_timeseries %}
            fetch{{ ts.model_name }}History(itemId);
            {% endfor %}
            {% endif %}
        }
    }, [id, fetchItem]);

    {% if model.m2m_fields %}
    {% for m2m in model.m2m_fields %}
    const fetch{{ m2m.target_model }}s = async (itemId: number, page: number) => {
        set{{ m2m.target_model }}Loading(true);
        try {
            const result = await get{{ model.name }}{{ m2m.target_model }}s(itemId, page, 5); // Small page size for detail view
            set{{ m2m.target_model }}Data(result.items);
            set{{ m2m.target_model }}Total(result.total);
            set{{ m2m.target_model }}Page(result.page);
        } catch (error) {
            console.error(error);
        } finally {
            set{{ m2m.target_model }}Loading(false);
        }
    };
    {% endfor %}
    {% endif %}

    {% if model.reverse_m2m %}
    {% for rel in model.reverse_m2m %}
    {% if rel.display %}
    const fetch{{ model.name }}{{ rel.source_model }}s = async (itemId: number, page: number) => {
        set{{ rel.name|replace('_', ' ')|title|replace(' ', '') }}Loading(true);
        try {
            const result = await get{{ model.name }}{{ rel.source_model }}s(itemId, page, 5);
            set{{ rel.name|replace('_', ' ')|title|replace(' ', '') }}Data(result.items);
            set{{ rel.name|replace('_', ' ')|title|replace(' ', '') }}Total(result.total);
            set{{ rel.name|replace('_', ' ')|title|replace(' ', '') }}Page(result.page);
        } catch (error) {
            console.error(error);
        } finally {
            set{{ rel.name|replace('_', ' ')|title|replace(' ', '') }}Loading(false);
        }
    };
    {% endif %}
    {% endfor %}
    {% endif %}

    {% if model.reverse_foreign_keys %}
    {% for rfk in model.reverse_foreign_keys %}
    {% if rfk.display %}
    const fetch{{ rfk.source_model }}s = async (itemId: number, page: number) => {
        set{{ rfk.source_model }}Loading(true);
        try {
            // Filter by foreign key
            const filters = { {{ rfk.source_fk_field }}: itemId };
            const result = await get{{ rfk.source_model }}s(page, 5, filters);
            set{{ rfk.source_model }}Data(result.items);
            set{{ rfk.source_model }}Total(result.total);
            set{{ rfk.source_model }}Page(result.page);
        } catch (error) {
            console.error(error);
        } finally {
            set{{ rfk.source_model }}Loading(false);
        }
    };
    {% endif %}
    {% endfor %}
    {% endif %}

    {% if model.reverse_timeseries %}
    {% for ts in model.reverse_timeseries %}
    const fetch{{ ts.model_name }}Realtime = async (itemId: number) => {
        try {
            const result = await get{{ ts.model_name }}Realtime(itemId);
            set{{ ts.model_name }}Realtime(result.data || []);
            set{{ ts.model_name }}Properties(result.properties || {});
        } catch (error) {
            console.error(error);
        }
    };

    const fetch{{ ts.model_name }}History = async (itemId: number) => {
        set{{ ts.model_name }}HistoryLoading(true);
        try {
            const result = await get{{ ts.model_name }}History(itemId);
            set{{ ts.model_name }}History(result);
            setTsHistoryLastRefreshed(new Date());
        } catch (error) {
            console.error(error);
        } finally {
            set{{ ts.model_name }}HistoryLoading(false);
        }
    };
    {% endfor %}

    // Auto-refresh realtime data
    useEffect(() => {
        let interval: ReturnType<typeof setInterval>;
        if (tsAutoRefresh && id) {
            interval = setInterval(() => {
                const itemId = parseInt(id);
                {% for ts in model.reverse_timeseries %}
                fetch{{ ts.model_name }}Realtime(itemId);
                {% endfor %}
            }, 5000);
        }
        return () => clearInterval(interval);
    }, [tsAutoRefresh, id]);

    // Auto-refresh history data
    useEffect(() => {
        let interval: ReturnType<typeof setInterval>;
        if (tsHistoryAutoRefresh && id) {
            interval = setInterval(() => {
                const itemId = parseInt(id);
                {% for ts in model.reverse_timeseries %}
                fetch{{ ts.model_name }}History(itemId);
                {% endfor %}
            }, 10000);
        }
        return () => clearInterval(interval);
    }, [tsHistoryAutoRefresh, id]);

    {% for ts in model.reverse_timeseries %}
    const toggle{{ ts.model_name }}Metric = (metric: string) => {
        set{{ ts.model_name }}SelectedMetrics(prev =>
            prev.includes(metric)
                ? prev.filter(m => m !== metric)
                : [...prev, metric]
        );
    };

    {% if ts.metric_field %}
    const {{ ts.model_name }}Metrics = React.useMemo(() => {
        const set = new Set<string>();
        {{ ts.model_name }}History.forEach((row: any) => {
            if (row.{{ ts.metric_field }}) set.add(row.{{ ts.metric_field }});
        });
        return Array.from(set);
    }, [{{ ts.model_name }}History]);

    useEffect(() => {
        if ({{ ts.model_name }}Metrics.length > 0 && {{ ts.model_name }}SelectedMetrics.length === 0) {
            set{{ ts.model_name }}SelectedMetrics({{ ts.model_name }}Metrics);
        }
    }, [{{ ts.model_name }}Metrics.length]);

    const {{ ts.model_name }}ChartData = React.useMemo(() => {
        const cutoff = {{ ts.model_name }}TimeRange === 'all' ? null : Date.now() - {
            '1h': 3600000, '6h': 21600000, '24h': 86400000,
            '7d': 604800000, '30d': 2592000000,
        }[{{ ts.model_name }}TimeRange];

        const filtered = {{ ts.model_name }}TimeRange === 'all'
            ? {{ ts.model_name }}History
            : {{ ts.model_name }}History.filter((row: any) =>
                new Date(row.{{ ts.time_field }}).getTime() >= cutoff!
            );

        const numGroups: Record<string, { time: number; value: number }[]> = {};
        const nonNumGroups: Record<string, { time: number; value: any }[]> = {};
        filtered.forEach((row: any) => {
            const metric = row.{{ ts.metric_field }};
            const rawVal = row.value?.value;
            if (rawVal === undefined || rawVal === null) return;
            const numVal = Number(rawVal);
            if (!isNaN(numVal) && typeof rawVal !== 'boolean') {
                if (!numGroups[metric]) numGroups[metric] = [];
                numGroups[metric].push({ time: new Date(row.{{ ts.time_field }}).getTime(), value: numVal });
            } else {
                if (!nonNumGroups[metric]) nonNumGroups[metric] = [];
                nonNumGroups[metric].push({ time: new Date(row.{{ ts.time_field }}).getTime(), value: rawVal });
            }
        });
        Object.values(numGroups).forEach(g => g.sort((a, b) => a.time - b.time));
        Object.values(nonNumGroups).forEach(g => g.sort((a, b) => a.time - b.time));
        return { numeric: numGroups, nonNumeric: nonNumGroups };
    }, [{{ ts.model_name }}History, {{ ts.model_name }}TimeRange]);
    {% endif %}
    {% endfor %}
    {% endif %}

    if (loading && !currentItem) {
        return (
            <div className="flex h-full items-center justify-center">
                <Loader2 className="h-8 w-8 animate-spin" />
            </div>
        );
    }

    if (!currentItem) {
        return (
            <div className="flex flex-col items-center justify-center space-y-4">
                <div className="text-xl font-semibold">Item not found</div>
                <Button onClick={() => navigate(-1)}>Go Back</Button>
            </div>
        );
    }

    return (
        <div className="space-y-6">
            <div className="flex items-center justify-between">
              <div className="flex items-center space-x-4">
                <Button variant="ghost" size="icon" onClick={() => navigate(-1)}>
                    <ArrowLeft className="h-4 w-4" />
                </Button>
                <h1 className="text-3xl font-bold tracking-tight">{{ model.name }} Details</h1>
              </div>

              <div className="flex items-center gap-2">
                {% if model.actions %}
                {% for action_name, action_config in model.actions.items() %}
                {(() => {
                    const actionPerms = {{ action_config.get("permissions", "da") | tojson }};
                    const roleChar = userRole[0];
                    if (!actionPerms.includes(roleChar)) return false;
                    const cond = {{ action_config.get("condition", None) | tojson }} as any;
                    let enabled = true;
                    if (cond && currentItem) {
                        const field = cond.field;
                        const op = cond.op;
                        const expected = cond.value;
                        const actual = (currentItem as any)[field];
                        if (op === 'eq') enabled = actual === expected;
                        else if (op === 'ne') enabled = actual !== expected;
                        else if (op === 'in') enabled = Array.isArray(expected) ? expected.includes(actual) : false;
                        else if (op === 'not_in') enabled = Array.isArray(expected) ? !expected.includes(actual) : true;
                        else if (op === 'gt') enabled = actual > expected;
                        else if (op === 'gte') enabled = actual >= expected;
                        else if (op === 'lt') enabled = actual < expected;
                        else if (op === 'lte') enabled = actual <= expected;
                        else if (op === 'contains') enabled = actual?.includes(expected);
                        else if (op === 'startswith') enabled = String(actual).startsWith(String(expected));
                        else if (op === 'endswith') enabled = String(actual).endsWith(String(expected));
                        else if (op === 'is_null') enabled = actual === null || actual === undefined;
                        else if (op === 'is_not_null') enabled = actual !== null && actual !== undefined;
                    }
                    return enabled;
                })() && (
                <Button
                    variant="outline"
                    size="sm"
                    onClick={async () => {
                        if (!currentItem) return;
                        try {
                            await perform{{ model.name }}{{ action_name.capitalize() }}(currentItem.id);
                            toast.success(t('common.success', 'Success'));
                            fetchItem(currentItem.id);
                        } catch (e) {
                            toast.error(t('common.error', 'Error'));
                        }
                    }}
                >
                    {{ action_name }}
                </Button>
                )}
                {% endfor %}
                {% endif %}

                {% if model.page_edit %}
                {hasPermission('u') && !isEditing && (
                  <Button variant="outline" size="sm" onClick={startEditing}>
                    <Pencil className="mr-2 h-4 w-4" /> {t('common.edit')}
                  </Button>
                )}
                {isEditing && (
                  <>
                    <Button variant="outline" size="sm" onClick={() => setIsEditing(false)}>
                      <X className="mr-2 h-4 w-4" /> {t('common.cancel')}
                    </Button>
                    <Button size="sm" type="button" onClick={handleEditSubmit(onEditSave)}>
                      <Save className="mr-2 h-4 w-4" /> {t('common.save')}
                    </Button>
                  </>
                )}
                {% endif %}
              </div>

              {% if model.refresh_interval %}
              <div className="flex items-center gap-2">
                 <span className="text-sm text-muted-foreground">{t('common.auto_refresh')}</span>
                 <Switch checked={autoRefresh} onCheckedChange={setAutoRefresh} />
                 {autoRefresh && (
                    <Select value={String(refreshInterval)} onValueChange={(v) => setRefreshInterval(Number(v))}>
                        <SelectTrigger className="w-[100px] h-8">
                            <SelectValue />
                        </SelectTrigger>
                        <SelectContent>
                            <SelectItem value="1000">1s</SelectItem>
                            <SelectItem value="5000">5s</SelectItem>
                            <SelectItem value="10000">10s</SelectItem>
                            <SelectItem value="30000">30s</SelectItem>
                        </SelectContent>
                    </Select>
                 )}
              </div>
              {% endif %}
            </div>

            <div className="grid gap-6 md:grid-cols-2">
                <Card>
                    <CardHeader>
                        <CardTitle>{% if model.page_edit %}{isEditing ? t('common.edit') + ' ' : ''}{% endif %}Basic Information</CardTitle>
                    </CardHeader>
                    <CardContent className="space-y-4">
                        {% if model.page_edit %}{isEditing ? (
                        <form id="detail-edit-form" className="space-y-4">
                            {% for field in model.fields %}
                            {% if not field.fk_info and 'u' in field.permissions %}{hasFieldPerm('{{ field.name }}', 'u'){% if field.name == model.owner_field %} && userRole !== 'user'{% endif %} && (
                            <div className="space-y-2">
                                <Label htmlFor="edit-{{ field.name }}">{t('{{ field.label_key }}')}</Label>
                                {% if field.ui_type == 'bool' %}
                                <Controller
                                    control={editControl}
                                    name="{{ field.name }}"
                                    defaultValue={ {{ 'true' if field.default else 'false' }} }
                                    render={({ field: { onChange, value } }) => (
                                        <Switch checked={value} onCheckedChange={onChange} id="edit-{{ field.name }}" />
                                    )}
                                />
                                {% elif field.ui_type == 'image' %}
                                <Controller
                                    control={editControl}
                                    name="{{ field.name }}"
                                    render={({ field: { onChange, value } }) => (
                                        <ImageUpload value={value} onChange={onChange} />
                                    )}
                                />
                                {% elif field.ui_type == 'file' %}
                                <Controller
                                    control={editControl}
                                    name="{{ field.name }}"
                                    render={({ field: { onChange, value } }) => (
                                        <FileUpload
                                            value={value}
                                            onChange={onChange}
                                            allowDownload={ {{ "true" if field.allow_download else "false" }} }
                                        />
                                    )}
                                />
                                {% elif field.is_enum %}
                                <Controller
                                    control={editControl}
                                    name="{{ field.name }}"
                                    render={({ field: { onChange, value } }) => {
                                        {% if model.module_name == "user" and model.name == "User" and field.name == "role" %}
                                        const filteredValues = userRole === 'developer'
                                            ? {{ field.enum_values | tojson }}
                                            : ({{ field.enum_values | tojson }} as string[]).filter(v => v !== 'developer');
                                        {% else %}
                                        const filteredValues = {{ field.enum_values | tojson }};
                                        {% endif %}
                                        return (
                                        <Select onValueChange={onChange} defaultValue={value}>
                                            <SelectTrigger>
                                                <SelectValue placeholder={`${t('common.select')} ${t('{{ field.label_key }}')}`} />
                                            </SelectTrigger>
                                            <SelectContent>
                                                {filteredValues.map((enumVal: string) => (
                                                    <SelectItem key={enumVal} value={enumVal}>{enumVal}</SelectItem>
                                                ))}
                                            </SelectContent>
                                        </Select>
                                        );
                                    }}
                                />
                                {% elif field.ui_type == 'time' %}
                                <Controller
                                    control={editControl}
                                    name="{{ field.name }}"
                                    render={({ field: { onChange, value } }) => (
                                        <TimePicker
                                            value={value}
                                            onChange={onChange}
                                            placeholder={`${t('common.select')} ${t('{{ field.label_key }}')}`}
                                        />
                                    )}
                                />
                                {% elif field.ui_type == 'json' %}
                                <Controller
                                    control={editControl}
                                    name="{{ field.name }}"
                                    defaultValue={ {% if field.json_kind == 'array' %}[]{% else %}{}{% endif %} }
                                    render={({ field: { onChange, value } }) => (
                                        {% if field.json_model_schema %}
                                        <JsonModelEditor
                                            schema={ {{ field.json_model_schema | tojson }} }
                                            value={value}
                                            onChange={onChange}
                                        />
                                        {% elif field.json_item_schema %}
                                        <JsonModelArrayEditor
                                            itemSchema={ {{ field.json_item_schema | tojson }} }
                                            value={value}
                                            onChange={onChange}
                                        />
                                        {% else %}
                                        <JsonInput
                                            value={value}
                                            onChange={onChange}
                                            jsonKind="{{ field.json_kind or 'object' }}"
                                            placeholder={ {% if field.json_kind == 'array' %}"[\\n  \\n]"{% else %}"{\\n  \\n}"{% endif %} }
                                        />
                                        {% endif %}
                                    )}
                                />
                                {% else %}
                                <Input
                                    id="edit-{{ field.name }}"
                                    {% if field.ui_type == 'int' or field.ui_type == 'float' %}
                                    type="number"
                                    {% elif field.ui_type == 'datetime' %}
                                    type="datetime-local"
                                    {% else %}
                                    type="text"
                                    {% endif %}
                                    {...register('{{ field.name }}', { required: {{ 'true' if field.required and not field.update_optional else 'false' }} })}
                                />
                                {% endif %}
                            </div>
                            )}{% endif %}
                            {% endfor %}
                        </form>
                        ) : ({% endif %}
                        {% if model.page_edit %}<>{% endif %}
                        {% for field in model.fields %}
                        {% if not field.fk_info and 'r' in field.permissions %}{hasFieldPerm('{{ field.name }}', 'r'){% if field.name == model.owner_field %} && userRole !== 'user'{% endif %} && (
                        <div className="space-y-1">
                            <Label className="text-muted-foreground">{t('{{ field.label_key }}')}</Label>
                            <div className="font-medium">
                                {% if field.ui_type == 'bool' %}
                                <Badge variant={currentItem.{{ field.name }} ? "default" : "secondary"}>
                                    {currentItem.{{ field.name }} ? 'Yes' : 'No'}
                                </Badge>
                                {% elif field.is_enum %}
                                <Badge variant="outline">{currentItem.{{ field.name }}}</Badge>
                                {% elif field.ui_type == 'image' %}
                                {currentItem.{{ field.name }} ? (
                                    <div className="relative aspect-video w-full max-w-sm overflow-hidden rounded-lg border bg-muted">
                                        <img
                                            src={currentItem.{{ field.name }}}
                                            alt="{{ field.name }}"
                                            className="h-full w-full object-cover"
                                        />
                                    </div>
                                ) : (
                                    <span className="text-muted-foreground italic">No image</span>
                                )}
                                {% elif field.ui_type == 'file' %}
                                {currentItem.{{ field.name }} ? (
                                    <FileUpload
                                        value={currentItem.{{ field.name }}}
                                        onChange={() => {}}
                                        readOnly={true}
                                        allowDownload={ {{ "true" if field.allow_download else "false" }} }
                                    />
                                ) : (
                                    <span className="text-muted-foreground italic">No file</span>
                                )}
                                {% elif field.ui_type == 'json' %}
                                <pre className="whitespace-pre-wrap break-words rounded-md border bg-muted/40 p-2 text-sm">
                                    {currentItem.{{ field.name }} !== undefined && currentItem.{{ field.name }} !== null
                                      ? JSON.stringify(currentItem.{{ field.name }}, null, 2)
                                      : '-'}
                                </pre>
                                {% elif field.ui_type == 'datetime' %}
                                <span className="text-muted-foreground">{formatDateTime(currentItem.{{ field.name }}, timeZone)}</span>
                                {% elif field.ui_type == 'time' %}
                                <span className="text-muted-foreground">{formatTime(currentItem.{{ field.name }})}</span>
                                {% else %}
                                {String(currentItem.{{ field.name }} ?? '-')}
                                {% endif %}
                            </div>
                        </div>
                        )}{% endif %}
                        {% endfor %}
                        {% if model.page_edit %}</>)}{% endif %}
                    </CardContent>
                </Card>

                {% if model.foreign_keys %}
                <Card>
                    <CardHeader>
                        <CardTitle>Related Information</CardTitle>
                    </CardHeader>
                    <CardContent className="space-y-6">
