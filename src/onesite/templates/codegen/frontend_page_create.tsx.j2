import React, { useEffect, useState } from 'react';
import { ArrowLeft, Loader2, Save } from 'lucide-react';
import { useForm, Controller } from 'react-hook-form';
import { useNavigate } from 'react-router-dom';
import { useTranslation } from 'react-i18next';
import { toast } from 'sonner';
import { use{{ model.name }}Store } from '../../stores/use{{ model.name }}Store';
import { Button } from '../../components/ui/button';
import { Input } from '../../components/ui/input';
import { JsonInput } from '../../components/ui/json-input';
import { JsonModelEditor, JsonModelArrayEditor } from '../../components/ui/json-model-editor';
import { Card, CardContent, CardHeader, CardTitle } from '../../components/ui/card';
import { Label } from '../../components/ui/label';
import { Switch } from '../../components/ui/switch';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '../../components/ui/select';
import { ImageUpload } from '../../components/ui/image-upload';
import { FileUpload } from '../../components/ui/file-upload';
import { SearchableSelect } from '../../components/ui/searchable-select';
import { LinkTableOrderedSelect } from '../../components/ui/link-table-ordered-select';
import { TimePicker } from '../../components/ui/time-picker';
{% for fk in model.foreign_keys %}
import { get{{ fk.target_model }}s } from '../../services/{{ fk.target_service }}';
{% endfor %}
{% if model.m2m_fields %}
{% for m2m in model.m2m_fields %}
import { get{{ m2m.target_model }}s } from '../../services/{{ m2m.target_service }}';
{% endfor %}
{% endif %}

const Create{{ model.name }}Page: React.FC = () => {
  const { t } = useTranslation();
  const navigate = useNavigate();
  const { createItem } = use{{ model.name }}Store();
  const [submitting, setSubmitting] = useState(false);

  // Role-based permissions
  const userRole = (localStorage.getItem('user_role') || 'user') as 'user' | 'admin' | 'developer';
  const rolePermissions: Record<string, string> = {{ model.role_permissions | tojson }};
  const userPerms = rolePermissions[userRole] || '';

  // Field-level role-based permissions (Layer 2)
  const fieldRolePerms: Record<string, Record<string, string>> = {
  {% for field in model.fields %}
  {% if field.role_permissions %}
    "{{ field.name }}": {{ field.role_permissions | tojson }},
  {% endif %}
  {% endfor %}
  };
  const hasFieldPerm = (fieldName: string, perm: 'c' | 'r' | 'u') => {
    const fp = fieldRolePerms[fieldName];
    if (!fp) return true;
    return (fp[userRole] || '').includes(perm);
  };

  {% for field in model.fields %}
  {% if field.fk_info %}
  const [{{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels, set{{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels] = useState<Record<string, string>>({});
  {% endif %}
  {% endfor %}
  {% if model.m2m_fields %}
  {% for m2m in model.m2m_fields %}
  const [{{ m2m.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels, set{{ m2m.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels] = useState<Record<string, string>>({});
  {% endfor %}
  {% endif %}

  const { register, handleSubmit, reset, setValue, control } = useForm();

  const onSubmit = async (values: any) => {
    setSubmitting(true);
    try {
      await createItem(values);
      toast.success(t('toast.create_success', 'Created'));
      navigate('/{{ model.module_name }}s');
    } catch (error) {
      toast.error(t('toast.save_failed', 'Save failed'));
      console.error(error);
    } finally {
      setSubmitting(false);
    }
  };

  return (
    <div className="space-y-6">
      <div className="flex items-center gap-4">
        <Button variant="ghost" size="icon" onClick={() => navigate('/{{ model.module_name }}s')}>
          <ArrowLeft className="h-4 w-4" />
        </Button>
        <h1 className="text-3xl font-bold tracking-tight">{t('common.create')} {t('models.{{ model.module_name }}.name')}</h1>
      </div>

      <Card>
        <CardHeader>
          <CardTitle>{t('models.{{ model.module_name }}.name')}</CardTitle>
        </CardHeader>
        <CardContent>
          <form onSubmit={handleSubmit(onSubmit)} className="space-y-4">
            {% for field in model.fields %}
            {hasFieldPerm('{{ field.name }}', 'c'){% if field.name == model.owner_field %} && userRole !== 'user'{% endif %} && (
            <div className="space-y-2">
              <Label htmlFor="{{ field.name }}">{t('{{ field.label_key }}')}</Label>
              {% if field.ui_type == 'bool' %}
              <div className="flex items-center space-x-2">
                <Controller
                  control={control}
                  name="{{ field.name }}"
                  defaultValue={ {{ 'true' if field.default else 'false' }} }
                  render={({ field: { onChange, value } }) => (
                    <Switch checked={value} onCheckedChange={onChange} id="{{ field.name }}" />
                  )}
                />
                <Label htmlFor="{{ field.name }}" className="font-normal text-muted-foreground">
                  {t('{{ field.label_key }}')}
                </Label>
              </div>
              {% elif field.ui_type == 'image' %}
              <Controller
                control={control}
                name="{{ field.name }}"
                render={({ field: { onChange, value } }) => (
                  <ImageUpload value={value} onChange={onChange} />
                )}
              />
              {% elif field.ui_type == 'file' %}
              <Controller
                control={control}
                name="{{ field.name }}"
                render={({ field: { onChange, value } }) => (
                  <FileUpload
                    value={value}
                    onChange={onChange}
                    allowDownload={ {{ "true" if field.allow_download else "false" }} }
                  />
                )}
              />
              {% elif field.is_enum %}
              <Controller
                control={control}
                name="{{ field.name }}"
                render={({ field: { onChange, value } }) => {
                  {% if model.module_name == "user" and model.name == "User" and field.name == "role" %}
                  const filteredValues = userRole === 'developer'
                    ? {{ field.enum_values | tojson }}
                    : ({{ field.enum_values | tojson }} as string[]).filter(v => v !== 'developer');
                  {% else %}
                  const filteredValues = {{ field.enum_values | tojson }};
                  {% endif %}
                  return (
                    <Select onValueChange={onChange} defaultValue={value}>
                      <SelectTrigger>
                        <SelectValue placeholder={`${t('common.select')} ${t('{{ field.label_key }}')}`} />
                      </SelectTrigger>
                      <SelectContent>
                        {filteredValues.map((enumVal: string) => (
                          <SelectItem key={enumVal} value={enumVal}>{enumVal}</SelectItem>
                        ))}
                      </SelectContent>
                    </Select>
                  );
                }}
              />
              {% elif field.fk_info %}
              <Controller
                control={control}
                name="{{ field.name }}"
                render={({ field: { onChange, value } }) => (
                  <SearchableSelect
                    value={value}
                    onValueChange={onChange}
                    placeholder={`${t('common.select')} ${t('{{ field.label_key }}')}`}
                    searchPlaceholder={`${t('common.search')} ${t('models.{{ field.fk_info.target_service }}.name')}...`}
                    valueLabels={ {{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels }
                    loadOptions={async (query) => {
                      const filters = query ? { {{ field.fk_info.label_field }}: query } : undefined;
                      const response = await get{{ field.fk_info.target_model }}s(1, 20, filters);
                      return response.items.map((item: any) => ({
                        label: item.{{ field.fk_info.label_field }} || item.id,
                        value: item.id,
                      }));
                    }}
                  />
                )}
              />
              {% elif field.ui_type == 'time' %}
              <Controller
                control={control}
                name="{{ field.name }}"
                render={({ field: { onChange, value } }) => (
                  <TimePicker
                    value={value}
                    onChange={onChange}
                    placeholder={`${t('common.select')} ${t('{{ field.label_key }}')}`}
                  />
                )}
              />
              {% elif field.ui_type == 'json' %}
              <Controller
                control={control}
                name="{{ field.name }}"
                defaultValue={ {% if field.json_kind == 'array' %}[]{% else %}{}{% endif %} }
                render={({ field: { onChange, value } }) => (
                  {% if field.json_model_schema %}
                  <JsonModelEditor
                    schema={ {{ field.json_model_schema | tojson }} }
                    value={value}
                    onChange={onChange}
                  />
                  {% elif field.json_item_schema %}
                  <JsonModelArrayEditor
                    itemSchema={ {{ field.json_item_schema | tojson }} }
                    value={value}
                    onChange={onChange}
                  />
                  {% else %}
                  <JsonInput
                    value={value}
                    onChange={onChange}
                    jsonKind="{{ field.json_kind or 'object' }}"
                    placeholder={ {% if field.json_kind == 'array' %}"[\\n  \\n]"{% else %}"{\\n  \\n}"{% endif %} }
                  />
                  {% endif %}
                )}
              />
              {% else %}
              <Input
                id="{{ field.name }}"
                {% if field.ui_type == 'int' or field.ui_type == 'float' %}
                type="number"
                {% elif field.ui_type == 'datetime' %}
                type="datetime-local"
                {% else %}
                type="text"
                {% endif %}
                {...register('{{ field.name }}', { required: {{ 'true' if field.required and not field.create_optional else 'false' }} })}
              />
              {% endif %}
            </div>
            )}
            {% endfor %}

            {% if model.m2m_fields %}
            {% for m2m in model.m2m_fields %}
            <div className="space-y-2">
              <Label>{t('models.{{ m2m.target_service }}.name')}s</Label>
              <Controller
                control={control}
                name="{{ m2m.name }}"
                render={({ field: { onChange, value } }) => (
                  {% if m2m.order_field %}
                  <LinkTableOrderedSelect
                    value={value}
                    onValueChange={onChange}
                    placeholder={`${t('common.select')} ${t('models.{{ m2m.target_service }}.name')}s`}
                    searchPlaceholder={`${t('common.search')} ${t('models.{{ m2m.target_service }}.name')}...`}
                    valueLabels={ {{ m2m.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels }
                    loadOptions={async (query) => {
                      const filters = query ? { {{ m2m.label_field }}: query } : undefined;
                      const response = await get{{ m2m.target_model }}s(1, 20, filters);
                      return response.items.map((item: any) => ({
                        label: item.{{ m2m.label_field }} || item.id,
                        value: item.id,
                      }));
                    }}
                  />
                  {% else %}
                  <SearchableSelect
                    value={value}
                    onValueChange={onChange}
                    multiple={true}
                    placeholder={`${t('common.select')} ${t('models.{{ m2m.target_service }}.name')}s`}
                    searchPlaceholder={`${t('common.search')} ${t('models.{{ m2m.target_service }}.name')}...`}
                    valueLabels={ {{ m2m.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels }
                    loadOptions={async (query) => {
                      const filters = query ? { {{ m2m.label_field }}: query } : undefined;
                      const response = await get{{ m2m.target_model }}s(1, 20, filters);
                      return response.items.map((item: any) => ({
                        label: item.{{ m2m.label_field }} || item.id,
                        value: item.id,
                      }));
                    }}
                  />
                  {% endif %}
                )}
              />
            </div>
            {% endfor %}
            {% endif %}

            <div className="flex justify-end space-x-2 pt-4">
              <Button variant="outline" type="button" onClick={() => navigate('/{{ model.module_name }}s')}>
                {t('common.cancel')}
              </Button>
              <Button type="submit" disabled={submitting}>
                {submitting ? (
                  <><Loader2 className="mr-2 h-4 w-4 animate-spin" /> {t('common.saving', 'Saving...')}</>
                ) : (
                  <><Save className="mr-2 h-4 w-4" /> {t('common.save')}</>
                )}
              </Button>
            </div>
          </form>
        </CardContent>
      </Card>
    </div>
  );
};

export default Create{{ model.name }}Page;
