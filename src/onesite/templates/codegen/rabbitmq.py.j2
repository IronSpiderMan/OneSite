import aio_pika
from app.core.config import settings
import logging
import asyncio
from typing import Callable, Awaitable, Dict

logger = logging.getLogger(__name__)

{% if rabbitmq.url %}
class RabbitMQManager:
    def __init__(self):
        self.connection = None
        self.channel = None
        self._consumers: Dict[str, Callable[[aio_pika.abc.AbstractIncomingMessage], Awaitable[None]]] = {}

    async def connect(self):
        try:
            self.connection = await aio_pika.connect_robust(settings.RABBITMQ_URL)
            self.channel = await self.connection.channel()
            logger.info("Connected to RabbitMQ")
            # Auto-start registered consumers
            await self._start_all_consumers()
        except Exception as e:
            logger.error(f"Failed to connect to RabbitMQ: {e}")

    def register_consumer(self, queue_name: str, callback: Callable[[aio_pika.abc.AbstractIncomingMessage], Awaitable[None]]):
        """
        Register a callback for a specific queue. 
        Must be called BEFORE rabbitmq_manager.connect() (usually in app/consumers/__init__.py)
        """
        self._consumers[queue_name] = callback
        logger.info(f"Registered consumer for queue: {queue_name}")

    async def _start_all_consumers(self):
        if not self.channel:
            return
        
        for queue_name, callback in self._consumers.items():
            queue = await self.channel.declare_queue(queue_name, durable=True)
            await queue.consume(callback)
            logger.info(f"Started consuming from queue: {queue_name}")

    async def disconnect(self):
        if self.connection:
            await self.connection.close()

rabbitmq_manager = RabbitMQManager()
{% else %}
# RabbitMQ not configured in site_config.json
rabbitmq_manager = None
{% endif %}
