from typing import Optional, List, Dict, Any
from datetime import datetime{% if model.fields | selectattr('ui_type', 'equalto', 'time') | list %}, time{% endif %}
from sqlmodel import SQLModel, Field
from app.models.{{ model.source_module }} import {{ model.name }}{% for imp in model.schema_imports %}, {{ imp }}{% endfor %}

{% macro py_default(v) -%}
{%- if v is sameas true -%}True
{%- elif v is sameas false -%}False
{%- elif v is none -%}None
{%- elif v is number -%}{{ v }}
{%- else -%}'{{ v|string|replace("'", "\\'") }}'
{%- endif -%}
{%- endmacro %}

# Shared properties
class {{ model.name }}Base(SQLModel):
{% set ns = namespace(has_field=false) %}
{% for field in model.fields %}
    {% if 'r' in field.permissions and field.name != 'id' %}
    {{ field.name }}: {{ field.type }}
    {% set ns.has_field = true %}
    {% endif %}
{% endfor %}
{% if not ns.has_field %}
    pass
{% endif %}


# Properties to receive via API on creation
class {{ model.name }}Create(SQLModel):
{% set ns = namespace(has_field=false) %}
{% for field in model.fields %}
    {% if 'c' in field.permissions and field.name != 'id' %}
    {% if field.required and not field.create_optional %}
    {% if model.is_notification_table and field.name == 'user_id' %}
    # user_id is optional in create - None means broadcast to all users
    user_id: Optional[int] = None
    {% else %}
    {{ field.name }}: {{ field.type }}
    {% endif %}
    {% else %}
    {% if field.default_factory == 'list' %}
    {{ field.name }}: {{ field.type }} = Field(default_factory=list)
    {% elif field.default_factory == 'dict' %}
    {{ field.name }}: {{ field.type }} = Field(default_factory=dict)
    {% else %}
    {{ field.name }}: {{ field.type }} = {{ py_default(field.default) }}
    {% endif %}
    {% endif %}
    {% set ns.has_field = true %}
    {% endif %}
{% endfor %}
{% if model.m2m_fields %}
    {% for m2m in model.m2m_fields %}
    {{ m2m.name }}: Optional[List[int]] = []
    {% set ns.has_field = true %}
    {% endfor %}
{% endif %}
{% if not ns.has_field %}
    pass
{% endif %}

# Properties to receive via API on update
class {{ model.name }}Update(SQLModel):
{% set ns = namespace(has_field=false) %}
{% for field in model.fields %}
    {% if 'u' in field.permissions and field.name != 'id' %}
    {% if field.type.startswith('Optional[') %}
    {{ field.name }}: {{ field.type }} = None
    {% else %}
    {{ field.name }}: Optional[{{ field.type }}] = None
    {% endif %}
    {% set ns.has_field = true %}
    {% endif %}
{% endfor %}
{% if model.m2m_fields %}
    {% for m2m in model.m2m_fields %}
    {{ m2m.name }}: Optional[List[int]] = None
    {% set ns.has_field = true %}
    {% endfor %}
{% endif %}

{% if not ns.has_field %}
    pass
{% endif %}

class {{ model.name }}Read({{ model.name }}Base):
    id: int
{% for fk in model.foreign_keys %}
    {{ fk.name }}_label: Optional[str] = None
