import request from '../utils/request';

const API_URL = '/{{ model.module_name }}s';

export interface {{ model.name }} {
    id: number;
{% for field in model.fields %}
    {% if field.name != 'id' and 'r' in field.permissions %}
    {{ field.name }}: {{ 'Record<string, any>' if 'Dict[' in field.type else 'any[]' if 'List[' in field.type else 'string' if 'str' in field.type else 'number' if 'int' in field.type or 'float' in field.type else 'boolean' if 'bool' in field.type else 'any' }};
    {% endif %}
{% endfor %}
}

export interface PaginatedResponse<T> {
    items: T[];
    total: number;
    page: number;
    size: number;
    total_pages: number;
}

export const get{{ model.name }}s = async (page = 1, size = 20, filters?: Record<string, any>) => {
    let url = `${API_URL}/?page=${page}&size=${size}`;
    if (filters) {
        Object.entries(filters).forEach(([key, value]) => {
            if (value !== undefined && value !== null) {
                url += `&${key}=${encodeURIComponent(String(value))}`;
            }
        });
    }
    const response = await request.get<PaginatedResponse<{{ model.name }}>>(url);
    return response.data;
};

export const get{{ model.name }} = async (id: number) => {
    const response = await request.get<{{ model.name }}>(`${API_URL}/${id}`);
    return response.data;
};

export const create{{ model.name }} = async (data: any) => {
    const response = await request.post<{{ model.name }}>(`${API_URL}/`, data);
    return response.data;
};

export const update{{ model.name }} = async (id: number, data: any) => {
    const response = await request.put<{{ model.name }}>(`${API_URL}/${id}`, data);
    return response.data;
};

export const delete{{ model.name }} = async (id: number) => {
    const response = await request.delete<{{ model.name }}>(`${API_URL}/${id}`);
    return response.data;
};

export const bulkDelete{{ model.name }} = async (ids: number[]) => {
    const response = await request.post<{ deleted: number }>(`${API_URL}/bulk_delete`, { ids });
    return response.data;
};

{% if model.visualize %}
export interface {{ model.name }}Stats {
    labels: string[];
    values: number[];
    title: string;
}

export const get{{ model.name }}Stats = async ({% if model.visualize.get('time_field') %}period?: string{% endif %}) => {
    let url = `${API_URL}/stats`;
    {% if model.visualize.get('time_field') %}
    if (period) {
        url += `?period=${period}`;
    }
    {% endif %}
    const response = await request.get<{{ model.name }}Stats>(url);
    return response.data;
};
{% endif %}

{% if model.actions %}
{% for action_name, action_config in model.actions.items() %}
export const perform{{ model.name }}{{ action_name.capitalize() }} = async (id: number) => {
    const response = await request.post<{{ model.name }}>(`${API_URL}/${id}/actions/{{ action_name }}`);
    return response.data;
};
{% endfor %}
{% endif %}

{% if model.module_name == "user" and model.name == "User" %}
export const getMe = async () => {
    const response = await request.get<{{ model.name }}>(`${API_URL}/me`);
    return response.data;
};

export const updateMe = async (data: any) => {
    const response = await request.put<{{ model.name }}>(`${API_URL}/me`, data);
    return response.data;
};
{% endif %}

{% if model.m2m_fields %}
{% for m2m in model.m2m_fields %}
import { {{ m2m.target_model }} } from './{{ m2m.target_model.lower() }}';
export const get{{ model.name }}{{ m2m.target_model }}s = async (id: number, page = 1, size = 20) => {
    const response = await request.get<PaginatedResponse<{{ m2m.target_model }}>>(`${API_URL}/${id}/{{ m2m.target_endpoint }}?page=${page}&size=${size}`);
    return response.data;
};
{% if m2m.order_field %}
export type {{ model.name }}{{ m2m.target_model }}WithMeta = { id: number; label: string; order: number };
export const get{{ model.name }}{{ m2m.target_model }}sWithMeta = async (id: number, page = 1, size = 50) => {
    const response = await request.get<PaginatedResponse<{{ model.name }}{{ m2m.target_model }}WithMeta>>(`${API_URL}/${id}/{{ m2m.target_endpoint }}_with_meta?page=${page}&size=${size}`);
    return response.data;
};
{% endif %}
{% endfor %}
{% endif %}

{% if model.reverse_m2m %}
{% for rel in model.reverse_m2m %}
import { {{ rel.source_model }} } from './{{ rel.source_model.lower() }}';
export const get{{ model.name }}{{ rel.source_model }}s = async (id: number, page = 1, size = 20) => {
    const response = await request.get<PaginatedResponse<{{ rel.source_model }}>>(`${API_URL}/${id}/{{ rel.name }}?page=${page}&size=${size}`);
    return response.data;
};
{% endfor %}
{% endif %}

{% if model.importable or model.exportable %}
// Import/Export functions
{% if model.exportable %}
export const export{{ model.name }}s = async () => {
    const response = await request.post<Blob>(`${API_URL}/export`, {}, {
        responseType: 'blob'
    });
    // Create download link for the returned file
    const url = window.URL.createObjectURL(new Blob([response.data]));
    const link = document.createElement('a');
    link.href = url;
    link.setAttribute('download', '{{ model.module_name }}s_export.csv');
    document.body.appendChild(link);
    link.click();
    link.remove();
    window.URL.revokeObjectURL(url);
};
{% endif %}

{% if model.importable %}
export interface ImportResult {
    success: number;
    failed: number;
    errors: string[];
}

export const import{{ model.name }}s = async (file: File): Promise<ImportResult> => {
    const formData = new FormData();
    formData.append('file', file);
    const response = await request.post<ImportResult>(`${API_URL}/import`, formData, {
        headers: { 'Content-Type': 'multipart/form-data' }
    });
    return response.data;
};
{% endif %}

{% if model.importable and not model.exportable %}
export const download{{ model.name }}Template = async () => {
    const response = await request.get(`${API_URL}/export/template`, {
        responseType: 'blob'
    });
    const url = window.URL.createObjectURL(new Blob([response.data]));
    const link = document.createElement('a');
    link.href = url;
    link.setAttribute('download', '{{ model.module_name }}_template.csv');
    document.body.appendChild(link);
    link.click();
    link.remove();
    window.URL.revokeObjectURL(url);
};
{% endif %}
{% endif %}
