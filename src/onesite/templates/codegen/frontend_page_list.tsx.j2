import React, { useState, useEffect } from 'react';
import { Plus, Pencil, Trash2, Loader2, Eye } from 'lucide-react';
import { useForm, Controller } from 'react-hook-form';
import { useNavigate } from 'react-router-dom';
import { useTranslation } from 'react-i18next';
import { toast } from 'sonner';
import { {{ model.name }}{% if model.m2m_fields %}{% for m2m in model.m2m_fields %}, get{{ model.name }}{{ m2m.target_model }}s{% endfor %}{% endif %} } from '../../services/{{ model.module_name }}';
import { use{{ model.name }}Store } from '../../stores/use{{ model.name }}Store';
import { Button } from '../../components/ui/button';
import { Input } from '../../components/ui/input';
import { JsonInput } from '../../components/ui/json-input';
import { JsonModelEditor, JsonModelArrayEditor } from '../../components/ui/json-model-editor';
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from '../../components/ui/table';
import { Modal } from '../../components/ui/modal';
import { Label } from '../../components/ui/label';
import { Badge } from '../../components/ui/badge';
import { Switch } from '../../components/ui/switch';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '../../components/ui/select';
import { ImageUpload } from '../../components/ui/image-upload';
import { FileUpload } from '../../components/ui/file-upload';
import { SearchableSelect } from '../../components/ui/searchable-select';
import { AlertDialog, AlertDialogAction, AlertDialogCancel, AlertDialogContent, AlertDialogDescription, AlertDialogFooter, AlertDialogHeader, AlertDialogTitle } from '../../components/ui/alert-dialog';
{% for fk in model.foreign_keys %}
import { get{{ fk.target_model }}s, get{{ fk.target_model }} } from '../../services/{{ fk.target_service }}';
{% endfor %}
{% if model.m2m_fields %}
{% for m2m in model.m2m_fields %}
import { get{{ m2m.target_model }}s } from '../../services/{{ m2m.target_service }}';
{% endfor %}
{% endif %}

const {{ model.name }}Page: React.FC = () => {
  const { t } = useTranslation();
  const navigate = useNavigate();
  const { data, loading, fetchData, fetchItem, createItem, updateItem, deleteItem } = use{{ model.name }}Store();
  const [isModalOpen, setIsModalOpen] = useState(false);
  const [editingId, setEditingId] = useState<number | null>(null);
  const [deleteOpen, setDeleteOpen] = useState(false);
  const [deleteId, setDeleteId] = useState<number | null>(null);
  const [isDeleting, setIsDeleting] = useState(false);
  const [searchValues, setSearchValues] = useState<Record<string, any>>({});
  {% for field in model.fields %}
  {% if field.fk_info %}
  const [{{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels, set{{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels] = useState<Record<string, string>>({});
  {% endif %}
  {% endfor %}
  {% if model.m2m_fields %}
  {% for m2m in model.m2m_fields %}
  const [{{ m2m.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels, set{{ m2m.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels] = useState<Record<string, string>>({});
  {% endfor %}
  {% endif %}

  const { register, handleSubmit, reset, setValue, control } = useForm();

  {% if model.auto_refresh %}
  const [autoRefresh, setAutoRefresh] = useState(false);
  const [refreshInterval, setRefreshInterval] = useState({{ model.refresh_interval or 5000 }});

  useEffect(() => {
    let interval: ReturnType<typeof setInterval>;
    if (autoRefresh) {
      interval = setInterval(() => {
        fetchData(use{{ model.name }}Store.getState().page, use{{ model.name }}Store.getState().size);
      }, refreshInterval);
    }
    return () => clearInterval(interval);
  }, [autoRefresh, refreshInterval, fetchData]);
  {% endif %}

  useEffect(() => {
    fetchData();
  }, [fetchData]);

  const handleCreate = () => {
    setEditingId(null);
    reset();
    {% for field in model.fields %}
    {% if field.fk_info %}
    set{{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels({});
    {% endif %}
    {% endfor %}
    {% if model.m2m_fields %}
    {% for m2m in model.m2m_fields %}
    setValue('{{ m2m.name }}', []);
    set{{ m2m.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels({});
    {% endfor %}
    {% endif %}
    setIsModalOpen(true);
  };

  const handleEdit = async (record: {{ model.name }}) => {
    setEditingId(record.id);
    const full = await fetchItem(record.id);
    const item = full || record;
    // Set form values
    {% for field in model.fields %}
    {% if ('c' in field.permissions or 'u' in field.permissions) and 'r' in field.permissions %}
    setValue('{{ field.name }}', item.{{ field.name }});
    {% endif %}
    {% endfor %}
    {% for field in model.fields %}
    {% if field.fk_info %}
    try {
      if (item.{{ field.name }}) {
        const fkItem = await get{{ field.fk_info.target_model }}(item.{{ field.name }});
        if (fkItem) {
          set{{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels({ [String(fkItem.id)]: fkItem.{{ field.fk_info.label_field }} || String(fkItem.id) });
        } else {
          set{{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels({});
        }
      } else {
        set{{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels({});
      }
    } catch (error) {
      console.error(error);
      set{{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels({});
    }
    {% endif %}
    {% endfor %}
    {% if model.m2m_fields %}
    {% for m2m in model.m2m_fields %}
    try {
      const rel = await get{{ model.name }}{{ m2m.target_model }}s(record.id, 1, 200);
      setValue('{{ m2m.name }}', rel.items.map((x: any) => x.id));
      set{{ m2m.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels(Object.fromEntries(rel.items.map((x: any) => [String(x.id), x.{{ m2m.label_field }} || String(x.id)])));
    } catch (error) {
      console.error(error);
      set{{ m2m.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels({});
    }
    {% endfor %}
    {% endif %}
    setIsModalOpen(true);
  };

  const requestDelete = (id: number) => {
    setDeleteId(id);
    setDeleteOpen(true);
  };

  const confirmDelete = async () => {
    if (!deleteId) return;
    setIsDeleting(true);
    try {
      await deleteItem(deleteId);
      toast.success(t('toast.delete_success', 'Deleted'));
    } catch (error) {
      toast.error(t('toast.delete_failed', 'Delete failed'));
      console.error(error);
    } finally {
      setIsDeleting(false);
      setDeleteOpen(false);
      setDeleteId(null);
    }
  };

  const onSubmit = async (values: any) => {
    try {
      if (editingId) {
        await updateItem(editingId, values);
        toast.success(t('toast.update_success', 'Updated'));
      } else {
        await createItem(values);
        toast.success(t('toast.create_success', 'Created'));
      }
      setIsModalOpen(false);
    } catch (error) {
      toast.error(t('toast.save_failed', 'Save failed'));
      console.error(error);
    }
  };

  const applySearch = () => {
    const next: Record<string, any> = {};
    {% for field in model.fields %}
    {% if field.is_search_field and field.name != 'id' %}
    {% if field.ui_type == 'bool' %}
    if (searchValues['{{ field.name }}'] === 'true') next['{{ field.name }}'] = true;
    if (searchValues['{{ field.name }}'] === 'false') next['{{ field.name }}'] = false;
    {% elif field.ui_type == 'datetime' %}
    if (searchValues['{{ field.name }}_from']) next['{{ field.name }}_from'] = `${searchValues['{{ field.name }}_from']}T00:00:00`;
    if (searchValues['{{ field.name }}_to']) next['{{ field.name }}_to'] = `${searchValues['{{ field.name }}_to']}T23:59:59`;
    {% elif field.is_enum %}
    if (searchValues['{{ field.name }}'] && searchValues['{{ field.name }}'] !== '__all__') next['{{ field.name }}'] = searchValues['{{ field.name }}'];
    {% elif field.ui_type == 'str' %}
    if (searchValues['{{ field.name }}']) next['{{ field.name }}'] = searchValues['{{ field.name }}'];
    {% endif %}
    {% endif %}
    {% endfor %}
    fetchData(1, use{{ model.name }}Store.getState().size, undefined, next);
  };

  const resetSearch = () => {
    setSearchValues({});
    fetchData(1, use{{ model.name }}Store.getState().size, undefined, {});
  };

  return (
    <div className="space-y-6">
      <AlertDialog open={deleteOpen} onOpenChange={setDeleteOpen}>
        <AlertDialogContent>
          <AlertDialogHeader>
            <AlertDialogTitle>{t('alert.delete_title', 'Confirm deletion')}</AlertDialogTitle>
            <AlertDialogDescription>
              {t('common.confirm_delete')}
            </AlertDialogDescription>
          </AlertDialogHeader>
          <AlertDialogFooter>
            <AlertDialogCancel disabled={isDeleting}>{t('common.cancel')}</AlertDialogCancel>
            <AlertDialogAction disabled={isDeleting} onClick={confirmDelete}>
              {isDeleting ? t('common.loading') : t('common.delete')}
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>

      <div className="flex items-center justify-between">
        <h1 className="text-3xl font-bold tracking-tight">{t('models.{{ model.module_name }}.name')}s</h1>
        <div className="flex items-center gap-4">
          {% if model.auto_refresh %}
          <div className="flex items-center gap-2">
             <span className="text-sm text-muted-foreground">{t('common.auto_refresh')}</span>
             <Switch checked={autoRefresh} onCheckedChange={setAutoRefresh} />
             {autoRefresh && (
                <Select value={String(refreshInterval)} onValueChange={(v) => setRefreshInterval(Number(v))}>
                    <SelectTrigger className="w-[100px] h-8">
                        <SelectValue />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectItem value="1000">1s</SelectItem>
                        <SelectItem value="5000">5s</SelectItem>
                        <SelectItem value="10000">10s</SelectItem>
                        <SelectItem value="30000">30s</SelectItem>
                    </SelectContent>
                </Select>
             )}
          </div>
          {% endif %}
          <Button onClick={handleCreate}>
            <Plus className="mr-2 h-4 w-4" /> {t('common.create')} {t('models.{{ model.module_name }}.name')}
          </Button>
        </div>
      </div>

      {% set ns = namespace(has_search_fields=false) %}
      {% for field in model.fields %}
      {% if field.is_search_field and (field.ui_type in ['bool','str','datetime'] or field.is_enum) and field.name != 'id' %}
      {% set ns.has_search_fields = true %}
      {% endif %}
      {% endfor %}
      {% if ns.has_search_fields %}
      <div className="rounded-md border bg-card p-4">
        <div className="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <div className="text-sm font-medium">{t('common.filters', 'Filters')}</div>
          <div className="flex items-center gap-2">
            <Button variant="outline" size="sm" type="button" onClick={resetSearch}>{t('common.reset', 'Reset')}</Button>
            <Button size="sm" type="button" onClick={applySearch}>{t('common.search')}</Button>
          </div>
        </div>
        <div className="mt-4 max-h-[40vh] overflow-auto pr-2">
          <div className="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {% for field in model.fields %}
          {% if field.is_search_field and (field.ui_type in ['bool','str','datetime'] or field.is_enum) and field.name != 'id' %}
          <div className="space-y-2">
            <Label>{t('{{ field.label_key }}')}</Label>
            {% if field.ui_type == 'bool' %}
            <Select
              value={searchValues['{{ field.name }}'] || '__all__'}
              onValueChange={(v) => setSearchValues((s) => ({ ...s, ['{{ field.name }}']: v }))}
            >
              <SelectTrigger className="h-9">
                <SelectValue placeholder={t('common.all', 'All')} />
              </SelectTrigger>
              <SelectContent>
                <SelectItem value="__all__">{t('common.all', 'All')}</SelectItem>
                <SelectItem value="true">{t('common.yes', 'Yes')}</SelectItem>
                <SelectItem value="false">{t('common.no', 'No')}</SelectItem>
              </SelectContent>
            </Select>
            {% elif field.ui_type == 'datetime' %}
            <div className="flex items-center gap-2">
              <Input
                type="date"
                className="h-9"
                value={searchValues['{{ field.name }}_from'] || ''}
                onChange={(e) => setSearchValues((s) => ({ ...s, ['{{ field.name }}_from']: e.target.value }))}
              />
              <span className="text-muted-foreground text-sm">-</span>
              <Input
                type="date"
                className="h-9"
                value={searchValues['{{ field.name }}_to'] || ''}
                onChange={(e) => setSearchValues((s) => ({ ...s, ['{{ field.name }}_to']: e.target.value }))}
              />
            </div>
            {% elif field.is_enum %}
            <Select
              value={searchValues['{{ field.name }}'] || '__all__'}
              onValueChange={(v) => setSearchValues((s) => ({ ...s, ['{{ field.name }}']: v }))}
            >
              <SelectTrigger className="h-9">
                <SelectValue placeholder={t('common.all', 'All')} />
              </SelectTrigger>
              <SelectContent>
                <SelectItem value="__all__">{t('common.all', 'All')}</SelectItem>
                {% for enum_val in field.enum_values %}
                <SelectItem value="{{ enum_val }}">{{ enum_val }}</SelectItem>
                {% endfor %}
              </SelectContent>
            </Select>
            {% elif field.ui_type == 'str' %}
            <Input
              className="h-9"
              value={searchValues['{{ field.name }}'] || ''}
              onChange={(e) => setSearchValues((s) => ({ ...s, ['{{ field.name }}']: e.target.value }))}
              placeholder={t('common.search')}
            />
            {% endif %}
          </div>
          {% endif %}
          {% endfor %}
          </div>
        </div>
      </div>
      {% endif %}

      <div className="border rounded-md">
        <Table>
          <TableHeader>
            <TableRow>
              {% for field in model.fields %}
              {% if 'r' in field.permissions %}
              <TableHead>{t('{{ field.label_key }}')}</TableHead>
              {% endif %}
              {% endfor %}
              <TableHead className="w-[100px]">{t('common.actions')}</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {loading ? (
                <TableRow>
                    <TableCell colSpan={ {{ model.fields|length + 1 }} } className="h-24 text-center">
                        <Loader2 className="h-6 w-6 animate-spin mx-auto" />
                    </TableCell>
                </TableRow>
            ) : data.length === 0 ? (
                <TableRow>
                    <TableCell colSpan={ {{ model.fields|length + 1 }} } className="h-24 text-center">
                        {t('common.no result')}
                    </TableCell>
                </TableRow>
            ) : (
                data.map((item) => (
                <TableRow key={item.id}>
                    {% for field in model.fields %}
                    {% if 'r' in field.permissions %}
                    <TableCell>
                        {% if field.ui_type == 'bool' %}
                        <Badge variant={item.{{ field.name }} ? "default" : "secondary"}>
                            {item.{{ field.name }} ? 'Yes' : 'No'}
                        </Badge>
                        {% elif field.ui_type == 'image' %}
                        <div className="h-10 w-10 overflow-hidden rounded-md border bg-muted">
                            <img
                                src={item.{{ field.name }} || 'https://placehold.co/100?text=No+Image'}
                                alt="{{ field.name }}"
                                className="h-full w-full object-cover"
                                onError={(e) => {
                                    (e.target as HTMLImageElement).src = 'https://placehold.co/100?text=Error';
                                }}
                            />
                        </div>
                        {% elif field.ui_type == 'file' %}
                        {item.{{ field.name }} ? (
                            <div className="flex items-center gap-2">
                                <span
                                    className="flex items-center text-primary cursor-pointer hover:underline"
                                    title={item.{{ field.name }}}
                                    onClick={() => {
                                        // TODO: Open preview
                                    }}
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="mr-1"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                                    File
                                </span>
                                {% if field.allow_download %}
                                <a
                                    href={item.{{ field.name }}}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    className="text-muted-foreground hover:text-primary"
                                    title="Download"
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                                </a>
                                {% endif %}
                            </div>
                        ) : (
                            <span className="text-muted-foreground">-</span>
                        )}
                        {% elif field.is_enum %}
                        <Badge variant="outline">{item.{{ field.name }}}</Badge>
                        {% elif field.ui_type == 'json' %}
                        {item.{{ field.name }} !== undefined && item.{{ field.name }} !== null
                          ? (typeof item.{{ field.name }} === 'object' ? JSON.stringify(item.{{ field.name }}) : String(item.{{ field.name }}))
                          : '-'}
                        {% else %}
                        {String(item.{{ field.name }})}
                        {% endif %}
                    </TableCell>
                    {% endif %}
                    {% endfor %}
                    <TableCell className="flex items-center gap-2">
                        <Button variant="ghost" size="icon" onClick={() => navigate(`/{{ model.module_name }}s/${item.id}`)}>
                            <Eye className="h-4 w-4" />
                        </Button>
                        <Button variant="ghost" size="icon" onClick={() => handleEdit(item)}>
                            <Pencil className="h-4 w-4" />
                        </Button>
                        <Button variant="ghost" size="icon" className="text-destructive" onClick={() => requestDelete(item.id)}>
                            <Trash2 className="h-4 w-4" />
                        </Button>
                    </TableCell>
                </TableRow>
                ))
            )}
          </TableBody>
        </Table>
      </div>

      {/* Pagination Controls */}
      <div className="flex items-center justify-end space-x-2">
        <div className="flex-1 text-sm text-muted-foreground">
            Page {use{{ model.name }}Store(state => state.page)} of {Math.ceil(use{{ model.name }}Store(state => state.total) / use{{ model.name }}Store(state => state.size)) || 1}
        </div>
        <div className="space-x-2">
            <Button
                variant="outline"
                size="sm"
                onClick={() => fetchData(use{{ model.name }}Store.getState().page - 1, use{{ model.name }}Store.getState().size)}
                disabled={use{{ model.name }}Store(state => state.page) <= 1 || loading}
            >
                {t('common.previous')}
            </Button>
            <Button
                variant="outline"
                size="sm"
                onClick={() => fetchData(use{{ model.name }}Store.getState().page + 1, use{{ model.name }}Store.getState().size)}
                disabled={use{{ model.name }}Store(state => state.page) >= Math.ceil(use{{ model.name }}Store(state => state.total) / use{{ model.name }}Store(state => state.size)) || loading}
            >
                {t('common.next')}
            </Button>
        </div>
      </div>

      <Modal
        title={editingId ? `${t('common.edit')} {{ model.name }}` : `${t('common.create')} {{ model.name }}`}
        isOpen={isModalOpen}
        onClose={() => setIsModalOpen(false)}
      >
            <div className="max-h-[80vh] overflow-y-auto pr-2">
                <form onSubmit={handleSubmit(onSubmit)} className="space-y-4">
          {% for field in model.fields %}
          {% set can_create = 'c' in field.permissions %}
          {% set can_update = 'u' in field.permissions %}
          {(!editingId ? {{ 'true' if can_create else 'false' }} : {{ 'true' if can_update else 'false' }}) && (
          <div className="space-y-2">
            <Label htmlFor="{{ field.name }}">{t('{{ field.label_key }}')}</Label>
            {% if field.ui_type == 'bool' %}
            <div className="flex items-center space-x-2">
                <Controller
                    control={control}
                    name="{{ field.name }}"
                    defaultValue={ {{ 'true' if field.default else 'false' }} }
                    render={({ field: { onChange, value } }) => (
                        <Switch checked={value} onCheckedChange={onChange} id="{{ field.name }}" />
                    )}
                />
                <Label htmlFor="{{ field.name }}" className="font-normal text-muted-foreground">
                    {t('{{ field.label_key }}')}
                </Label>
            </div>
            {% elif field.ui_type == 'image' %}
            <Controller
                control={control}
                name="{{ field.name }}"
                render={({ field: { onChange, value } }) => (
                    <ImageUpload
                        value={value}
                        onChange={onChange}
                    />
                )}
            />
            {% elif field.ui_type == 'file' %}
                        <Controller
                            control={control}
                            name="{{ field.name }}"
                            render={({ field: { onChange, value } }) => (
                                <FileUpload
                                    value={value}
                                    onChange={onChange}
                                    allowDownload={ {{ "true" if field.allow_download else "false" }} }
                                />
                            )}
                        />
                        {% elif field.is_enum %}
            <Controller
                control={control}
                name="{{ field.name }}"
                render={({ field: { onChange, value } }) => (
                    <Select onValueChange={onChange} defaultValue={value}>
                        <SelectTrigger>
                            <SelectValue placeholder={`${t('common.select')} ${t('{{ field.label_key }}')}`} />
                        </SelectTrigger>
                        <SelectContent>
                            {% for enum_val in field.enum_values %}
                            <SelectItem value="{{ enum_val }}">{{ enum_val }}</SelectItem>
                            {% endfor %}
                        </SelectContent>
                    </Select>
                )}
            />
            {% elif field.fk_info %}
            <Controller
                control={control}
                name="{{ field.name }}"
                render={({ field: { onChange, value } }) => (
                    <SearchableSelect
                        value={value}
                        onValueChange={onChange}
                        placeholder={`${t('common.select')} ${t('{{ field.label_key }}')}`}
                        searchPlaceholder={`${t('common.search')} ${t('models.{{ field.fk_info.target_service }}.name')}...`}
                        valueLabels={ {{ field.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels }
                        loadOptions={async (query) => {
                            const response = await get{{ field.fk_info.target_model }}s(1, 20, query);
                            return response.items.map((item: any) => ({
                                label: item.{{ field.fk_info.label_field }} || item.id,
                                value: item.id
                            }));
                        }}
                    />
                )}
            />
            {% elif field.ui_type == 'json' %}
            <Controller
                control={control}
                name="{{ field.name }}"
                defaultValue={ {% if field.json_kind == 'array' %}[]{% else %}{}{% endif %} }
                render={({ field: { onChange, value } }) => (
                    {% if field.json_model_schema %}
                    <JsonModelEditor
                        schema={ {{ field.json_model_schema | tojson }} }
                        value={value}
                        onChange={onChange}
                    />
                    {% elif field.json_item_schema %}
                    <JsonModelArrayEditor
                        itemSchema={ {{ field.json_item_schema | tojson }} }
                        value={value}
                        onChange={onChange}
                    />
                    {% else %}
                    <JsonInput
                        value={value}
                        onChange={onChange}
                        jsonKind="{{ field.json_kind or 'object' }}"
                        placeholder={ {% if field.json_kind == 'array' %}"[\\n  \\n]"{% else %}"{\\n  \\n}"{% endif %} }
                    />
                    {% endif %}
                )}
            />
            {% else %}
            <Input
                id="{{ field.name }}"
                {% if field.ui_type == 'int' or field.ui_type == 'float' %}
                type="number"
                {% else %}
                type="text"
                {% endif %}
                {...register('{{ field.name }}', { required: !editingId ? {{ 'true' if field.required and not field.create_optional else 'false' }} : {{ 'true' if field.required and not field.update_optional else 'false' }} })}
            />
            {% endif %}
          </div>
          )}
          {% endfor %}

          {% if model.m2m_fields %}
          {% for m2m in model.m2m_fields %}
          <div className="space-y-2">
            <Label>{t('models.{{ m2m.target_service }}.name')}s</Label>
            <Controller
                control={control}
                name="{{ m2m.name }}"
                render={({ field: { onChange, value } }) => (
                    <SearchableSelect
                        value={value}
                        onValueChange={onChange}
                        multiple={true}
                        placeholder={`${t('common.select')} ${t('models.{{ m2m.target_service }}.name')}s`}
                        searchPlaceholder={`${t('common.search')} ${t('models.{{ m2m.target_service }}.name')}...`}
                        valueLabels={ {{ m2m.name|replace('_', ' ')|title|replace(' ', '') }}ValueLabels }
                        loadOptions={async (query) => {
                            const response = await get{{ m2m.target_model }}s(1, 20, query);
                            return response.items.map((item: any) => ({
                                label: item.{{ m2m.label_field }} || item.id,
                                value: item.id
                            }));
                        }}
                    />
                )}
            />
          </div>
          {% endfor %}
          {% endif %}
          <div className="flex justify-end space-x-2 pt-4">
            <Button variant="outline" type="button" onClick={() => setIsModalOpen(false)}>{t('common.cancel')}</Button>
            <Button type="submit">{t('common.save')}</Button>
          </div>
        </form>
            </div>
      </Modal>
    </div>
  );
};

export default {{ model.name }}Page;
