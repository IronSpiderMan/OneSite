import React from 'react';
import SettingsPage from './pages/Settings';
import DashboardPage from './pages/Dashboard';
{% for model in models %}
{% if not model.is_singleton %}
import {{ model.name }}Page from './pages/{{ model.module_name }}';
import {{ model.name }}DetailPage from './pages/{{ model.module_name }}/detail';
{% if model.page_edit %}
import Create{{ model.name }}Page from './pages/{{ model.module_name }}/create';
{% endif %}
{% elif model.module_name != 'system_config' and model.module_name != 'custom_config' %}
import {{ model.name }}Page from './pages/{{ model.module_name }}';
{% endif %}
{% endfor %}

export const GeneratedRoutes = [
  {
    path: '/dashboard',
    element: <DashboardPage />,
  },
  {
    path: '/settings',
    element: <SettingsPage />,
  },
{% for model in models %}
{% if not model.is_singleton %}
  {
    path: '/{{ model.module_name }}s',
    element: <{{ model.name }}Page />,
  },
  {% if model.page_edit %}
  {
    path: '/{{ model.module_name }}s/new',
    element: <Create{{ model.name }}Page />,
  },
  {% endif %}
  {
    path: '/{{ model.module_name }}s/:id',
    element: <{{ model.name }}DetailPage />,
  },
{% elif model.module_name != 'system_config' and model.module_name != 'custom_config' %}
  {
    path: '/{{ model.module_name }}',
    element: <{{ model.name }}Page />,
  },
{% endif %}
{% endfor %}
];
