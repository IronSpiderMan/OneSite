    async def create(self, session: AsyncSession, obj_in: {{ model.name }}Create) -> {{ model.name }}:
        {% if model.fields | selectattr('is_unique') | list %}
        # Check unique field constraints
        {% for field in model.fields %}
        {% if field.is_unique and field.name != 'id' %}
        if getattr(obj_in, "{{ field.name }}", None) is not None:
            if not await crud.check_unique_field(session, "{{ field.name }}", obj_in.{{ field.name }}):
                raise ValueError("{{ field.name }} already exists")
        {% endif %}
        {% endfor %}
        {% endif %}
        {% if model.is_notification_table %}
        # If user_id is None, broadcast to all active users
        if getattr(obj_in, "user_id", None) is None:
            from sqlmodel import select
            from app.models.user import User
            
            result = await session.exec(select(User.id).where(User.is_active == True))
            user_ids = result.all()
            
            if not user_ids:
                # No active users, return placeholder
                return {{ model.name }}(
                    title=obj_in.title,
                    summary=obj_in.summary,
                    content=obj_in.content,
                    is_read=False,
                    user_id=0
                )
            
            from datetime import datetime as dt
            created_at = dt.utcnow()
            created_objects = []
            
            for uid in user_ids:
                obj_data = obj_in.dict()
                obj_data["user_id"] = uid
                obj_data["created_at"] = created_at
                db_obj = {{ model.name }}(**obj_data)
                session.add(db_obj)
                created_objects.append(db_obj)
            
            await session.commit()
            
            # Refresh all objects to get their IDs
            for obj in created_objects:
                await session.refresh(obj)
            
            # Push notifications to all users
            for obj in created_objects:
                try:
                    payload = {
                        "type": "notification",
                        "data": {
                            "id": obj.id,
                            "title": obj.title,
                            "summary": obj.summary,
                            "created_at": obj.created_at.isoformat() if obj.created_at else None,
                            "is_read": obj.is_read,
                        }
                    }
                    await manager.send_personal_message(payload, obj.user_id)
                except Exception:
                    pass
            
            # Return the first created object as representative
            return created_objects[0] if created_objects else {{ model.name }}()
        {% endif %}
        obj = await crud.create(session, obj_in)

        {% if model.fields | selectattr('name', 'equalto', 'updated_at') | list %}
        # Auto-set updated_at on create
        from datetime import datetime as dt
        obj.updated_at = dt.utcnow()
        session.add(obj)
        await session.commit()
        await session.refresh(obj)
        {% endif %}

        {% if model.is_notification_table %}
        # Auto-push for notification
        try:
            created_at = getattr(obj, "created_at", None)
            payload = {
                "type": "notification",
                "data": {
                    "id": getattr(obj, "id", None),
                    "title": getattr(obj, "title", ""),
                    "summary": getattr(obj, "summary", ""),
                    "created_at": created_at.isoformat() if created_at else None,
                    "is_read": bool(getattr(obj, "is_read", False)),
                }
            }
            await manager.send_personal_message(payload, obj.user_id)
        except Exception:
            pass
        {% endif %}
        return obj

    async def update(self, session: AsyncSession, id: int, obj_in: {{ model.name }}Update) -> {{ model.name }}:
        """
        Update {{ model.name }} by ID with validation.
        Raises ValueError if unique constraint is violated.
        Raises NotFoundError if object doesn't exist.
        """
        db_obj = await crud.get(session, id)
        if not db_obj:
            raise ValueError("{{ model.name }} not found")
        
        {% if model.fields | selectattr('is_unique') | list %}
        # Check unique field constraints (only for fields being updated)
        {% for field in model.fields %}
        {% if field.is_unique and field.name != 'id' %}
        if getattr(obj_in, "{{ field.name }}", None) is not None and getattr(obj_in, "{{ field.name }}") != getattr(db_obj, "{{ field.name }}"):
            if not await crud.check_unique_field(session, "{{ field.name }}", obj_in.{{ field.name }}, exclude_id=id):
                raise ValueError("{{ field.name }} already exists")
        {% endif %}
        {% endfor %}
        {% endif %}

        obj = await crud.update(session, db_obj, obj_in)

        {% if model.fields | selectattr('name', 'equalto', 'updated_at') | list %}
        # Auto-update updated_at timestamp
        obj.updated_at = datetime.utcnow()
        session.add(obj)
        await session.commit()
        await session.refresh(obj)
        {% endif %}

        {% if model.is_notification_table %}
        # Auto-push read status
        try:
            if getattr(obj, "is_read", False):
                await manager.send_personal_message({"type": "read", "id": obj.id}, obj.user_id)
        except Exception:
            pass
        {% endif %}
        return obj

