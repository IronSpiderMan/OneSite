    {% if model.importable or model.exportable %}
    # Import/Export methods
    {% if model.exportable %}
    async def export_to_csv(
        self,
        session: AsyncSession,
        *,
        task_id: str,
        user_id: int,
        filters: Optional[dict] = None,
        ws_manager = None,
    ) -> str:
        """
        Export {{ model.name }} records to CSV.
        Returns the file path of the exported CSV.
        Foreign key fields are exported as labels (not IDs).
        """
        import csv
        import os
        from datetime import datetime
        from sqlmodel import select
        
        upload_dir = os.environ.get("UPLOAD_DIR", "uploads")
        export_dir = os.path.join(upload_dir, "exports")
        os.makedirs(export_dir, exist_ok=True)
        
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        filename = f"{{ model.module_name }}_export_{timestamp}.csv"
        filepath = os.path.join(export_dir, filename)

        # Write CSV with UTF-8 BOM for Excel compatibility
        with open(filepath, 'w', newline='', encoding='utf-8-sig') as f:
            writer = csv.writer(f)

            # Header - exclude id, created_at, updated_at for clean import/export cycle
            headers = [{% for field in model.fields %}{% if 'r' in field.permissions and field.name not in ['id', 'created_at', 'updated_at'] %}"{{ field.name }}"{% if not loop.last %}, {% endif %}{% endif %}{% endfor %}]
            writer.writerow(headers)
            
            {% if model.foreign_keys %}
            # Build FK label caches
            {% for fk in model.foreign_keys %}
            {{ fk.name }}_label_cache = {}
            {% endfor %}
            {% endif %}
            
            # Process in batches
            batch_size = 1000
            page = 1
            
            while True:
                items = await crud.get_multi(session, page=page, size=batch_size)
                if not items:
                    break
                
                {% if model.foreign_keys %}
                # Collect unique FK IDs for batch label resolution
                {% for fk in model.foreign_keys %}
                {{ fk.name }}_ids = list(set(
                    getattr(item, "{{ fk.name }}") for item in items 
                    if getattr(item, "{{ fk.name }}") is not None 
                    and getattr(item, "{{ fk.name }}") not in {{ fk.name }}_label_cache
                ))
                {% endfor %}
                
                # Batch fetch FK labels
                {% for fk in model.foreign_keys %}
                if {{ fk.name }}_ids:
                    from app.models.{{ fk.target_service }} import {{ fk.target_model }}
                    stmt = select({{ fk.target_model }}).where({{ fk.target_model }}.id.in_({{ fk.name }}_ids))
                    result = await session.exec(stmt)
                    for obj in result.all():
                        {{ fk.name }}_label_cache[obj.id] = getattr(obj, "{{ fk.label_field }}", None) or str(obj.id)
                {% endfor %}
                {% endif %}
                
                for item in items:
                    row = []
                    {% for field in model.fields %}
                    {% if 'r' in field.permissions and field.name not in ['id', 'created_at', 'updated_at'] %}
                    {% if field.fk_info %}
                    # FK field - export label instead of ID
                    fk_id = getattr(item, "{{ field.name }}", None)
                    if fk_id is None:
                        row.append("")
                    elif fk_id in {{ field.name }}_label_cache:
                        row.append({{ field.name }}_label_cache[fk_id])
                    else:
                        row.append(str(fk_id))
                    {% else %}
                    val = getattr(item, "{{ field.name }}", None)
                    # Convert to string, handle Enum/datetime specially
                    if val is None:
                        row.append("")
                    elif hasattr(val, 'value'):
                        # Enum type - get the value
                        row.append(str(val.value))
                    elif hasattr(val, 'isoformat'):
                        # datetime type - use ISO format
                        row.append(val.isoformat())
                    else:
                        row.append(str(val))
                    {% endif %}
                    {% endif %}
                    {% endfor %}
                    writer.writerow(row)
                
                page += 1
                
                if len(items) < batch_size:
                    break
        
        return filepath
    {% endif %}

    {% if model.importable %}
    async def import_from_csv(
        self,
        session: AsyncSession,
        *,
        task_id: str,
        user_id: int,
        file: Any,
        dry_run: bool = False,
        ws_manager = None,
    ) -> dict:
        """
        Import {{ model.name }} records from CSV.
        Uses upsert logic: if record with same {{ model.import_key }} exists, update it; otherwise create new.
        Foreign key fields in CSV should be labels (not IDs), and will be resolved to IDs.
        """
        import csv
        import io
        import json
        import ast
        from datetime import datetime
        from sqlmodel import select

        contents = await file.read()
        csv_file = io.StringIO(contents.decode('utf-8-sig'))
        reader = csv.DictReader(csv_file)

        rows = list(reader)

        stats = {"success": 0, "failed": 0, "created": 0, "updated": 0, "errors": []}
        import_key = "{{ model.import_key }}"

        {% if model.foreign_keys %}
        # Build FK label-to-ID caches
        {% for fk in model.foreign_keys %}
        {{ fk.name }}_cache = {}
        {% endfor %}
        
        # Pre-fetch all FK targets for label resolution
        {% for fk in model.foreign_keys %}
        from app.models.{{ fk.target_service }} import {{ fk.target_model }} as {{ fk.target_model }}_model
        stmt = select({{ fk.target_model }}_model)
        result = await session.exec(stmt)
        for obj in result.all():
            label = getattr(obj, "{{ fk.label_field }}", None) or str(obj.id)
            {{ fk.name }}_cache[label] = obj.id
            {{ fk.name }}_cache[str(obj.id)] = obj.id  # Also allow ID as fallback
        {% endfor %}
        {% endif %}

        for idx, row in enumerate(rows, 1):
            try:
                # Get the unique field value
                key_value = row.get(import_key)
                if not key_value:
                    stats["failed"] += 1
                    stats["errors"].append(f"Row {idx}: Missing import key '{import_key}'")
                    continue

                # Check if record exists
                existing = await crud.get_by_{{ model.import_key }}(session, key_value)
                is_update = existing is not None

                # Build data object from row
                obj_data = {}
                {% for field in model.fields %}
                {% if field.name != 'id' and 'c' in field.permissions %}
                {% if field.name not in ['created_at', 'updated_at'] %}
                if "{{ field.name }}" in row:
                    value = row["{{ field.name }}"]
                    {% if field.fk_info %}
                    # FK field - resolve label to ID
                    if not value:
                        obj_data["{{ field.name }}"] = None
                    elif value in {{ field.name }}_cache:
                        obj_data["{{ field.name }}"] = {{ field.name }}_cache[value]
                    else:
                        # Try to find by searching
                        from app.models.{{ field.fk_info.target_service }} import {{ field.fk_info.target_model }} as {{ field.fk_info.target_model }}_import
                        stmt = select({{ field.fk_info.target_model }}_import).where(
                            getattr({{ field.fk_info.target_model }}_import, "{{ field.fk_info.label_field }}") == value
                        )
                        fk_result = await session.exec(stmt)
                        fk_obj = fk_result.first()
                        if fk_obj:
                            obj_data["{{ field.name }}"] = fk_obj.id
                            {{ field.name }}_cache[value] = fk_obj.id
                        else:
                            raise ValueError(f"Foreign key '{value}' not found for field '{{ field.name }}'")
                    {% elif field.ui_type == 'int' %}
                    obj_data["{{ field.name }}"] = int(value) if value else None
                    {% elif field.ui_type == 'float' %}
                    obj_data["{{ field.name }}"] = float(value) if value else None
                    {% elif field.ui_type == 'bool' %}
                    obj_data["{{ field.name }}"] = value.lower() in ('true', '1', 'yes', 'on') if value else False
                    {% elif field.ui_type == 'json' %}
                    obj_data["{{ field.name }}"] = ast.literal_eval(value) if value else []
                    {% elif field.is_enum %}
                    obj_data["{{ field.name }}"] = value
                    {% else %}
                    obj_data["{{ field.name }}"] = value
                    {% endif %}
                {% endif %}
                {% endif %}
                {% endfor %}

                if not dry_run:
                    if is_update:
                        # Update existing record (updated_at auto-set in update method)
                        obj_in = {{ model.name }}Update(**obj_data)
                        await self.update(session, existing.id, obj_in)
                        stats["updated"] += 1
                    else:
                        # Create new record (created_at and updated_at auto-set in create method)
                        obj_in = {{ model.name }}Create(**obj_data)
                        await self.create(session, obj_in)
                        stats["created"] += 1

                stats["success"] += 1

            except Exception as e:
                stats["failed"] += 1
                stats["errors"].append(f"Row {idx}: {str(e)}")

        return stats
    {% endif %}
    {% endif %}

    {% if model.visualize %}
    async def get_stats(
        self,
        session: AsyncSession,
        *,
        label_field: str,
        value_field: str,
        aggregation: str = "count",
        {% if model.visualize.get('time_field') %}
        time_field: Optional[str] = None,
        period: Optional[str] = "day",
        {% endif %}
    ) -> dict:
        """
        Get statistics for {{ model.name }} visualization.
        """
        from sqlalchemy import func, extract, case, cast, String
        from datetime import datetime, timedelta

        model = {{ model.name }}

        {% if model.visualize.get('time_field') %}
        if time_field:
            # Time-based aggregation (line chart)
            time_col = getattr(model, time_field)
            value_col = getattr(model, value_field)

            if period == "day":
                date_trunc = func.date(time_col)
            elif period == "week":
                date_trunc = func.date(func.date_trunc('week', time_col))
            elif period == "month":
                date_trunc = func.date(func.date_trunc('month', time_col))
            else:
                date_trunc = func.date(time_col)

            if aggregation == "count":
                stmt = select(date_trunc, func.count(model.id)).group_by(date_trunc)
            elif aggregation == "sum":
                stmt = select(date_trunc, func.coalesce(func.sum(value_col), 0)).group_by(date_trunc)
            elif aggregation == "avg":
                stmt = select(date_trunc, func.coalesce(func.avg(value_col), 0)).group_by(date_trunc)
            elif aggregation == "min":
                stmt = select(date_trunc, func.min(value_col)).group_by(date_trunc)
            elif aggregation == "max":
                stmt = select(date_trunc, func.max(value_col)).group_by(date_trunc)
            else:
                stmt = select(date_trunc, func.count(model.id)).group_by(date_trunc)

            result = await session.exec(stmt)
            rows = result.all()

            labels = []
            values = []
            for row in rows:
                date_val = row[0]
                if isinstance(date_val, datetime):
                    labels.append(date_val.strftime("%Y-%m-%d"))
                elif hasattr(date_val, 'value'):
                    # Handle Enum types
                    labels.append(str(date_val.value))
                else:
                    labels.append(str(date_val))
                values.append(float(row[1]))

            return {
                "labels": labels,
                "values": values,
                "title": "{{ model.visualize.get('title', model.name + ' Statistics') }}",
            }
        {% else %}
        # Group by label field (bar/pie chart)
        label_col = getattr(model, label_field, None)
        value_col = getattr(model, value_field, None)
        if label_col is None:
            return {"labels": [], "values": [], "title": "{{ model.visualize.get('title', model.name + ' Statistics') }}"}

        if aggregation == "count":
            stmt = select(label_col, func.count(model.id)).group_by(label_col)
        elif aggregation == "sum":
            stmt = select(label_col, func.coalesce(func.sum(value_col), 0)).group_by(label_col)
        elif aggregation == "avg":
            stmt = select(label_col, func.coalesce(func.avg(value_col), 0)).group_by(label_col)
        elif aggregation == "min":
            stmt = select(label_col, func.min(value_col)).group_by(label_col)
        elif aggregation == "max":
            stmt = select(label_col, func.max(value_col)).group_by(label_col)
        else:
            stmt = select(label_col, func.count(model.id)).group_by(label_col)

        result = await session.exec(stmt)
        rows = result.all()

        def to_label(val):
            if val is None:
                return "None"
            # Handle Enum types - get .value instead of full representation
            if hasattr(val, 'value'):
                return str(val.value)
            return str(val)

        labels = [to_label(row[0]) for row in rows]
        values = [float(row[1]) for row in rows]

        return {
            "labels": labels,
            "values": values,
            "title": "{{ model.visualize.get('title', model.name + ' Statistics') }}",
        }
        {% endif %}
    {% endif %}

service = {{ model.name }}Service()
