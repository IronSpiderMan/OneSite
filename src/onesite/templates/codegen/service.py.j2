    async def get_multi(
        self,
        session: AsyncSession,
        *,
        q: Optional[str] = None,
        page: int = 1,
        size: int = 20,
        {% for field in model.fields %}
        {% if field.is_search_field and field.name != 'id' %}
        {% if field.ui_type == 'bool' %}
        {{ field.name }}: Optional[bool] = None,
        {% elif field.ui_type == 'datetime' %}
        {{ field.name }}_from: Optional[datetime] = None,
        {{ field.name }}_to: Optional[datetime] = None,
        {% elif field.ui_type == 'time' %}
        {{ field.name }}: Optional[time] = None,
        {% elif field.is_enum %}
        {{ field.name }}: Optional[str] = None,
        {% elif field.ui_type == 'str' %}
        {{ field.name }}: Optional[str] = None,
        {% endif %}
        {% endif %}
        {% endfor %}
        {% for fk in model.foreign_keys %}
        {{ fk.name }}: Optional[int] = None,
        {% endfor %}
    ) -> PaginatedResponse[{{ model.name }}]:
        """
        Get paginated list with optional search and filter support.
        Combines CRUD get_multi and count into PaginatedResponse.
        """
        # Get total count first
        total = await crud.count(
            session,
            q=q,
            {% for field in model.fields %}
            {% if field.is_search_field and field.name != 'id' %}
            {% if field.ui_type == 'bool' %}
            {{ field.name }}={{ field.name }},
            {% elif field.ui_type == 'datetime' %}
            {{ field.name }}_from={{ field.name }}_from,
            {{ field.name }}_to={{ field.name }}_to,
            {% elif field.ui_type == 'time' %}
            {{ field.name }}={{ field.name }},
            {% elif field.is_enum %}
            {{ field.name }}={{ field.name }},
            {% elif field.ui_type == 'str' %}
            {{ field.name }}={{ field.name }},
            {% endif %}
            {% endif %}
            {% endfor %}
            {% for fk in model.foreign_keys %}
            {{ fk.name }}={{ fk.name }},
            {% endfor %}
        )
        
        # Get items
        items = await crud.get_multi(
            session,
            q=q,
            page=page,
            size=size,
            {% for field in model.fields %}
            {% if field.is_search_field and field.name != 'id' %}
            {% if field.ui_type == 'bool' %}
            {{ field.name }}={{ field.name }},
            {% elif field.ui_type == 'datetime' %}
            {{ field.name }}_from={{ field.name }}_from,
            {{ field.name }}_to={{ field.name }}_to,
            {% elif field.ui_type == 'time' %}
            {{ field.name }}={{ field.name }},
            {% elif field.is_enum %}
            {{ field.name }}={{ field.name }},
            {% elif field.ui_type == 'str' %}
            {{ field.name }}={{ field.name }},
            {% endif %}
            {% endif %}
            {% endfor %}
            {% for fk in model.foreign_keys %}
            {{ fk.name }}={{ fk.name }},
            {% endfor %}
        )
        
        # Build response
        if size == -1:
            return PaginatedResponse.create(data=items, total=total, page=1, size=total)
        return PaginatedResponse.create(data=items, total=total, page=page, size=size)

    async def create(self, session: AsyncSession, obj_in: {{ model.name }}Create) -> {{ model.name }}:
        {% if model.fields | selectattr('is_unique') | list %}
        # Check unique field constraints
        {% for field in model.fields %}
        {% if field.is_unique and field.name != 'id' %}
        if getattr(obj_in, "{{ field.name }}", None) is not None:
            if not await crud.check_unique_field(session, "{{ field.name }}", obj_in.{{ field.name }}):
                raise ValueError("{{ field.name }} already exists")
        {% endif %}
        {% endfor %}
        {% endif %}
        {% if model.is_notification_table %}
        # If user_id is None, broadcast to all active users
        if getattr(obj_in, "user_id", None) is None:
            from sqlmodel import select
            from app.models.user import User
            
            result = await session.exec(select(User.id).where(User.is_active == True))
            user_ids = result.all()
            
            if not user_ids:
                # No active users, return placeholder
                return {{ model.name }}(
                    title=obj_in.title,
                    summary=obj_in.summary,
                    content=obj_in.content,
                    is_read=False,
                    user_id=0
                )
            
            from datetime import datetime as dt
            created_at = dt.utcnow()
            created_objects = []
            
            for uid in user_ids:
                obj_data = obj_in.dict()
                obj_data["user_id"] = uid
                obj_data["created_at"] = created_at
                db_obj = {{ model.name }}(**obj_data)
                session.add(db_obj)
                created_objects.append(db_obj)
            
            await session.commit()
            
            # Refresh all objects to get their IDs
            for obj in created_objects:
                await session.refresh(obj)
            
            # Push notifications to all users
            for obj in created_objects:
                try:
                    payload = {
                        "type": "notification",
                        "data": {
                            "id": obj.id,
                            "title": obj.title,
                            "summary": obj.summary,
                            "created_at": obj.created_at.isoformat() if obj.created_at else None,
                            "is_read": obj.is_read,
                        }
                    }
                    await manager.send_personal_message(payload, obj.user_id)
                except Exception:
                    pass
            
            # Return the first created object as representative
            return created_objects[0] if created_objects else {{ model.name }}()
        {% endif %}
        obj = await crud.create(session, obj_in)
        {% if model.is_notification_table %}
        # Auto-push for notification
        try:
            created_at = getattr(obj, "created_at", None)
            payload = {
                "type": "notification",
                "data": {
                    "id": getattr(obj, "id", None),
                    "title": getattr(obj, "title", ""),
                    "summary": getattr(obj, "summary", ""),
                    "created_at": created_at.isoformat() if created_at else None,
                    "is_read": bool(getattr(obj, "is_read", False)),
                }
            }
            await manager.send_personal_message(payload, obj.user_id)
        except Exception:
            pass
        {% endif %}
        return obj

    async def update(self, session: AsyncSession, id: int, obj_in: {{ model.name }}Update) -> {{ model.name }}:
        """
        Update {{ model.name }} by ID with validation.
        Raises ValueError if unique constraint is violated.
        Raises NotFoundError if object doesn't exist.
        """
        db_obj = await crud.get(session, id)
        if not db_obj:
            raise ValueError("{{ model.name }} not found")
        
        {% if model.fields | selectattr('is_unique') | list %}
        # Check unique field constraints (only for fields being updated)
        {% for field in model.fields %}
        {% if field.is_unique and field.name != 'id' %}
        if getattr(obj_in, "{{ field.name }}", None) is not None and getattr(obj_in, "{{ field.name }}") != getattr(db_obj, "{{ field.name }}"):
            if not await crud.check_unique_field(session, "{{ field.name }}", obj_in.{{ field.name }}, exclude_id=id):
                raise ValueError("{{ field.name }} already exists")
        {% endif %}
        {% endfor %}
        {% endif %}
        
        obj = await crud.update(session, db_obj, obj_in)
        {% if model.is_notification_table %}
        # Auto-push read status
        try:
            if getattr(obj, "is_read", False):
                await manager.send_personal_message({"type": "read", "id": obj.id}, obj.user_id)
        except Exception:
            pass
        {% endif %}
        return obj

    async def delete(self, session: AsyncSession, id: int) -> {{ model.name }}:
        return await crud.delete(session, id)

    {% if model.is_notification_table %}
    async def mark_all_read(self, session: AsyncSession, user_id: int) -> int:
        """
        Mark all unread notifications as read for a specific user.
        Returns the number of notifications updated.
        """
        updated_count = await crud.mark_all_read_by_user(session, user_id)
        {% if model.is_notification_table %}
        # Push read status for all to WebSocket
        try:
            # Push a single "all_read" event to notify the frontend to refresh
            await manager.send_personal_message({"type": "all_read", "user_id": user_id}, user_id)
        except Exception:
            pass
        {% endif %}
        return updated_count
    {% endif %}

    {% if model.m2m_fields %}
    # M2M Relationship methods
    {% for m2m in model.m2m_fields %}
    async def get_{{ m2m.target_endpoint }}(
        self,
        session: AsyncSession,
        {{ model.lower_name }}_id: int,
        page: int = 1,
        size: int = 20,
    ) -> PaginatedResponse[{{ m2m.target_model }}Read]:
        """
        Get {{ m2m.target_model }}s related to {{ model.name }}.
        """
        from app.models.{{ m2m.target_source_module }} import {{ m2m.target_model }}
        
        # Get target IDs
        target_ids = await crud.get_{{ m2m.target_endpoint }}(session, {{ model.lower_name }}_id)
        
        if not target_ids:
            return PaginatedResponse.create(data=[], total=0, page=page, size=size)
        
        # Count total
        total = len(target_ids)
        
        # Pagination
        skip = (page - 1) * size
        paginated_ids = target_ids[skip:skip + size]
        
        # Get items
        statement = select({{ m2m.target_model }}).where(col({{ m2m.target_model }}.id).in_(paginated_ids))
        result = await session.exec(statement)
        items = result.all()
        
        return PaginatedResponse.create(data=items, total=total, page=page, size=size)

    {% if m2m.order_field %}
    async def get_{{ m2m.target_endpoint }}_with_meta(
        self,
        session: AsyncSession,
        {{ model.lower_name }}_id: int,
        page: int = 1,
        size: int = 50,
    ) -> PaginatedResponse[{{ model.name }}{{ m2m.target_model }}Meta]:
        """
        Get {{ m2m.target_model }}s related to {{ model.name }} with link-table order.
        """
        rows, total = await crud.get_{{ m2m.target_endpoint }}_with_order(session, {{ model.lower_name }}_id, page, size)
        
        items = [
            {{ model.name }}{{ m2m.target_model }}Meta(id=r[0], label=str(r[1]), order=int(r[2] or 0))
            for r in rows
        ]
        
        return PaginatedResponse.create(data=items, total=total, page=page, size=size)
    {% endif %}
    {% endfor %}
    {% endif %}

