router = APIRouter(dependencies=[Depends(deps.get_current_user)])

@router.get("/", response_model=PaginatedResponse[{{ model.name }}Read])
async def read_{{ model.lower_name }}s(
    page: int = 1,
    size: int = 20,
    q: Optional[str] = Query(None, description="Search query"),
    {% for field in model.fields %}
    {% if field.is_search_field and field.name != 'id' %}
    {% if field.ui_type == 'bool' %}
    {{ field.name }}: Optional[bool] = Query(None, description="Filter by {{ field.name }}"),
    {% elif field.ui_type == 'datetime' %}
    {{ field.name }}_from: Optional[datetime] = Query(None, description="Filter by {{ field.name }} from"),
    {{ field.name }}_to: Optional[datetime] = Query(None, description="Filter by {{ field.name }} to"),
    {% elif field.is_enum %}
    {{ field.name }}: Optional[str] = Query(None, description="Filter by {{ field.name }}"),
    {% elif field.ui_type == 'str' %}
    {{ field.name }}: Optional[str] = Query(None, description="Filter by {{ field.name }}"),
    {% endif %}
    {% endif %}
    {% endfor %}
    {% for fk in model.foreign_keys %}
    {{ fk.name }}: Optional[int] = Query(None, description="Filter by {{ fk.name }}"),
    {% endfor %}
    session: AsyncSession = Depends(db.get_session),
) -> Any:
    # Calculate skip based on page and size
    skip = (page - 1) * size
    
    # Base statement
    statement = select({{ model.name }})
    
    # Apply search filter if query is present
    {% if model.search_field != 'id' %}
    if q:
        statement = statement.where(col({{ model.name }}.{{ model.search_field }}).ilike(f"%{q}%"))
    {% endif %}

    # Apply per-field filters (configured via site_props.is_search_field)
    {% for field in model.fields %}
    {% if field.is_search_field and field.name != 'id' %}
    {% if field.ui_type == 'bool' %}
    if {{ field.name }} is not None:
        statement = statement.where({{ model.name }}.{{ field.name }} == {{ field.name }})
    {% elif field.ui_type == 'datetime' %}
    if {{ field.name }}_from is not None:
        statement = statement.where({{ model.name }}.{{ field.name }} >= {{ field.name }}_from)
    if {{ field.name }}_to is not None:
        statement = statement.where({{ model.name }}.{{ field.name }} <= {{ field.name }}_to)
    {% elif field.is_enum %}
    if {{ field.name }}:
        statement = statement.where({{ model.name }}.{{ field.name }} == {{ field.name }})
    {% elif field.ui_type == 'str' %}
    if {{ field.name }}:
        statement = statement.where(col({{ model.name }}.{{ field.name }}).ilike("%" + {{ field.name }} + "%"))
    {% endif %}
    {% endif %}
    {% endfor %}

    # Apply foreign key filters
    {% for fk in model.foreign_keys %}
    if {{ fk.name }}:
        statement = statement.where({{ model.name }}.{{ fk.name }} == {{ fk.name }})
    {% endfor %}
    
    # Get total count (before limit/offset)
    total_statement = select(func.count()).select_from(statement.subquery())
    total_result = await session.exec(total_statement)
    total = total_result.one()
    
    # Apply pagination
    statement = statement.offset(skip).limit(size)
    result = await session.exec(statement)
    items = result.all()
    
    return PaginatedResponse.create(data=items, total=total, page=page, size=size)

@router.post("/", response_model={{ model.name }}Read)
async def create_{{ model.lower_name }}(
    *,
    session: AsyncSession = Depends(db.get_session),
    {{ model.lower_name }}_in: {{ model.name }}Create,
) -> Any:
    {%- for field in model.fields %}
    {%- if field.is_unique and field.name != 'id' %}
    if getattr({{ model.lower_name }}_in, "{{ field.name }}", None) is not None:
        statement = select({{ model.name }}).where({{ model.name }}.{{ field.name }} == getattr({{ model.lower_name }}_in, "{{ field.name }}"))
        result = await session.exec(statement)
        if result.first():
            raise HTTPException(status_code=400, detail="{{ field.name }} already exists")
    {%- endif %}
    {%- endfor %}
    return await service.create(session, {{ model.lower_name }}_in)

@router.get("/{id}", response_model={{ model.name }}Read)
async def read_{{ model.lower_name }}(
    *,
    session: AsyncSession = Depends(db.get_session),
    id: int,
) -> Any:
    {{ model.lower_name }} = await service.get(session, id)
    if not {{ model.lower_name }}:
        raise HTTPException(status_code=404, detail="{{ model.name }} not found")
    return {{ model.lower_name }}

@router.put("/{id}", response_model={{ model.name }}Read)
async def update_{{ model.lower_name }}(
    *,
    session: AsyncSession = Depends(db.get_session),
    id: int,
    {{ model.lower_name }}_in: {{ model.name }}Update,
) -> Any:
    {{ model.lower_name }} = await service.get(session, id)
    if not {{ model.lower_name }}:
        raise HTTPException(status_code=404, detail="{{ model.name }} not found")
        
    {%- for field in model.fields %}
    {%- if field.is_unique and field.name != 'id' %}
    if getattr({{ model.lower_name }}_in, "{{ field.name }}", None) is not None and getattr({{ model.lower_name }}_in, "{{ field.name }}") != getattr({{ model.lower_name }}, "{{ field.name }}"):
        statement = select({{ model.name }}).where({{ model.name }}.{{ field.name }} == getattr({{ model.lower_name }}_in, "{{ field.name }}"))
        result = await session.exec(statement)
        if result.first():
            raise HTTPException(status_code=400, detail="{{ field.name }} already exists")
    {%- endif %}
    {%- endfor %}

    {{ model.lower_name }} = await service.update(session, {{ model.lower_name }}, {{ model.lower_name }}_in)
    return {{ model.lower_name }}

@router.delete("/{id}", response_model={{ model.name }}Read)
async def delete_{{ model.lower_name }}(
    *,
    session: AsyncSession = Depends(db.get_session),
    id: int,
) -> Any:
    {{ model.lower_name }} = await service.get(session, id)
    if not {{ model.lower_name }}:
        raise HTTPException(status_code=404, detail="{{ model.name }} not found")
    {{ model.lower_name }} = await service.delete(session, id)
    return {{ model.lower_name }}

{% if model.m2m_fields %}
{% for m2m in model.m2m_fields %}
@router.get("/{id}/{{ m2m.target_endpoint }}", response_model=PaginatedResponse[{{ m2m.target_model }}Read])
async def read_{{ model.lower_name }}_{{ m2m.target_endpoint }}(
    *,
    session: AsyncSession = Depends(db.get_session),
    id: int,
    page: int = 1,
    size: int = 20,
) -> Any:
    """
    Get {{ m2m.target_model }}s related to {{ model.name }}
    """
    # 1. Find all target_ids in link table
    link_statement = select({{ m2m.link_model }}.{{ m2m.target_fk_field }}).where({{ m2m.link_model }}.{{ m2m.source_fk_field }} == id)
    link_result = await session.exec(link_statement)
    target_ids = link_result.all()
    
    if not target_ids:
        return PaginatedResponse.create(data=[], total=0, page=page, size=size)
        
    # 2. Find target objects
    skip = (page - 1) * size
    statement = select({{ m2m.target_model }}).where(col({{ m2m.target_model }}.id).in_(target_ids))
    
    # Count total
    total_statement = select(func.count()).select_from(statement.subquery())
    total_result = await session.exec(total_statement)
    total = total_result.one()
    
    # Pagination
    statement = statement.offset(skip).limit(size)
    result = await session.exec(statement)
    items = result.all()
    
    return PaginatedResponse.create(data=items, total=total, page=page, size=size)
{% endfor %}
{% endif %}

{% if model.m2m_fields %}
{% for m2m in model.m2m_fields %}
{% if m2m.order_field %}
@router.get("/{id}/{{ m2m.target_endpoint }}_with_meta", response_model=PaginatedResponse[{{ model.name }}{{ m2m.target_model }}Meta])
async def read_{{ model.lower_name }}_{{ m2m.target_endpoint }}_with_meta(
    *,
    session: AsyncSession = Depends(db.get_session),
    id: int,
    page: int = 1,
    size: int = 50,
) -> Any:
    """
    Get {{ m2m.target_model }}s related to {{ model.name }} with link-table order
    """
    skip = (page - 1) * size

    total_statement = select(func.count()).select_from({{ m2m.link_model }}).where({{ m2m.link_model }}.{{ m2m.source_fk_field }} == id)
    total_result = await session.exec(total_statement)
    total = total_result.one()

    statement = (
        select({{ m2m.target_model }}.id, {{ m2m.target_model }}.{{ m2m.label_field }}, {{ m2m.link_model }}.{{ m2m.order_field }})
        .join({{ m2m.link_model }}, {{ m2m.link_model }}.{{ m2m.target_fk_field }} == {{ m2m.target_model }}.id)
        .where({{ m2m.link_model }}.{{ m2m.source_fk_field }} == id)
        .order_by({{ m2m.link_model }}.{{ m2m.order_field }})
        .offset(skip)
        .limit(size)
    )
    result = await session.exec(statement)
    rows = result.all()
    items = [{{ model.name }}{{ m2m.target_model }}Meta(id=r[0], label=str(r[1]), order=int(r[2] or 0)) for r in rows]
    return PaginatedResponse.create(data=items, total=total, page=page, size=size)
{% endif %}
{% endfor %}
{% endif %}

{% if model.reverse_m2m %}
{% for rel in model.reverse_m2m %}
@router.get("/{id}/{{ rel.name }}", response_model=PaginatedResponse[{{ rel.source_model }}Read])
async def read_{{ model.lower_name }}_{{ rel.name }}(
    *,
    session: AsyncSession = Depends(db.get_session),
    id: int,
    page: int = 1,
    size: int = 20,
) -> Any:
    """
    Get {{ rel.source_model }}s related to {{ model.name }} (via M2M)
    """
    link_statement = select({{ rel.link_model }}.{{ rel.source_fk_field }}).where({{ rel.link_model }}.{{ rel.target_fk_field }} == id)
    link_result = await session.exec(link_statement)
    source_ids = link_result.all()

    if not source_ids:
        return PaginatedResponse.create(data=[], total=0, page=page, size=size)

    skip = (page - 1) * size
    statement = select({{ rel.source_model }}).where(col({{ rel.source_model }}.id).in_(source_ids))

    total_statement = select(func.count()).select_from(statement.subquery())
    total_result = await session.exec(total_statement)
    total = total_result.one()

    statement = statement.offset(skip).limit(size)
    result = await session.exec(statement)
    items = result.all()

    return PaginatedResponse.create(data=items, total=total, page=page, size=size)
{% endfor %}
{% endif %}
