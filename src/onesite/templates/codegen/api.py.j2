{% if model.is_notification_table %}
@router.get("/unread_count")
async def unread_count(
    *,
    session: AsyncSession = Depends(db.get_session),
    current_user: User = Depends(deps.get_current_user),
) -> Any:
    statement = select(func.count()).select_from({{ model.name }}).where(
        col({{ model.name }}.user_id) == current_user.id,
        col({{ model.name }}.is_read) == False,
    )
    result = await session.exec(statement)
    return {"unread": result.one()}

@router.get("/inbox", response_model=PaginatedResponse[{{ model.name }}Read])
async def inbox(
    *,
    session: AsyncSession = Depends(db.get_session),
    current_user: User = Depends(deps.get_current_user),
    page: int = 1,
    size: int = 20,
) -> Any:
    skip = (page - 1) * size
    statement = (
        select({{ model.name }})
        .where(col({{ model.name }}.user_id) == current_user.id)
        .order_by(col({{ model.name }}.created_at).desc())
    )
    total_statement = select(func.count()).select_from(statement.subquery())
    total_result = await session.exec(total_statement)
    total = total_result.one()
    result = await session.exec(statement.offset(skip).limit(size))
    items = result.all()
    return PaginatedResponse.create(data=items, total=total, page=page, size=size)

@router.put("/{id}/read", response_model={{ model.name }}Read)
async def mark_read(
    *,
    session: AsyncSession = Depends(db.get_session),
    current_user: User = Depends(deps.get_current_user),
    id: int,
) -> Any:
    n = await service.get(session, id)
    if not n:
        raise HTTPException(status_code=404, detail="{{ model.name }} not found")
    if getattr(n, "user_id", None) != current_user.id and not current_user.is_superuser:
        raise HTTPException(status_code=403, detail="Forbidden")
    if not getattr(n, "is_read", False):
        n = await service.update(session, id, {{ model.name }}Update(is_read=True))
    return n

@router.put("/mark_all_read")
async def mark_all_read(
