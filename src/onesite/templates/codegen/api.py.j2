{% if model.is_notification_table %}
@router.get("/unread_count")
async def unread_count(
    *,
    session: AsyncSession = Depends(db.get_session),
    current_user: User = Depends(deps.get_current_user),
) -> Any:
    statement = select(func.count()).select_from({{ model.name }}).where(
        col({{ model.name }}.user_id) == current_user.id,
        col({{ model.name }}.is_read) == False,
    )
    result = await session.exec(statement)
    return {"unread": result.one()}

@router.get("/inbox", response_model=PaginatedResponse[{{ model.name }}Read])
async def inbox(
    *,
    session: AsyncSession = Depends(db.get_session),
    current_user: User = Depends(deps.get_current_user),
    page: int = 1,
    size: int = 20,
) -> Any:
    skip = (page - 1) * size
    statement = (
        select({{ model.name }})
        .where(col({{ model.name }}.user_id) == current_user.id)
        .order_by(col({{ model.name }}.created_at).desc())
    )
    total_statement = select(func.count()).select_from(statement.subquery())
    total_result = await session.exec(total_statement)
    total = total_result.one()
    result = await session.exec(statement.offset(skip).limit(size))
    items = result.all()
    return PaginatedResponse.create(data=items, total=total, page=page, size=size)

@router.put("/{id}/read", response_model={{ model.name }}Read)
async def mark_read(
    *,
    session: AsyncSession = Depends(db.get_session),
    current_user: User = Depends(deps.get_current_user),
    id: int,
) -> Any:
    n = await service.get(session, id)
    if not n:
        raise HTTPException(status_code=404, detail="{{ model.name }} not found")
    if getattr(n, "user_id", None) != current_user.id and not current_user.is_superuser:
        raise HTTPException(status_code=403, detail="Forbidden")
    if not getattr(n, "is_read", False):
        n = await service.update(session, n, {{ model.name }}Update(is_read=True))
    return n

@router.post("/send", dependencies=[Depends(deps.get_current_active_superuser)])
async def send_notification(
    *,
    session: AsyncSession = Depends(db.get_session),
    payload: {{ model.name }}Send,
) -> Any:
    title = str(payload.title or "").strip()
    content = str(payload.content or "").strip()
    summary = str(payload.summary or "").strip()
    user_id = payload.user_id
    broadcast = bool(payload.broadcast)
    if not title or not content:
        raise HTTPException(status_code=400, detail="title/content required")

    # Determine broadcast mode: explicit broadcast=True OR user_id is None
    is_broadcast = broadcast or (user_id is None)
    
    created_count = 0
    if is_broadcast:
        q = await session.exec(select(User.id).where(User.is_active == True))
        user_ids = q.all()
        for uid in user_ids:
            obj_in = {{ model.name }}Create(title=title, summary=summary or title, content=content, user_id=uid, is_read=False)
            await service.create(session, obj_in)
            created_count += 1
    else:
        try:
            uid = int(user_id)
        except Exception:
            raise HTTPException(status_code=400, detail="invalid user_id")
        obj_in = {{ model.name }}Create(title=title, summary=summary or title, content=content, user_id=uid, is_read=False)
        await service.create(session, obj_in)
        created_count = 1
    return {"sent": created_count}
