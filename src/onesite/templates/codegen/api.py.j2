{% if not model.exportable %}
@router.get("/export/template")
async def export_{{ model.lower_name }}_template(
    *,
    current_user: User = Depends(deps.get_current_user),
) -> Any:
    """
    Download CSV template for importing {{ model.name }} records.
    """
    from fastapi.responses import StreamingResponse
    import io
    import csv

    output = io.StringIO()
    writer = csv.writer(output)

    # Write header with field names - exclude id, created_at, updated_at
    fields = [{% for field in model.fields %}{% if field.name not in ['id', 'created_at', 'updated_at'] and 'c' in field.permissions %}"{{ field.name }}"{% if not loop.last %}, {% endif %}{% endif %}{% endfor %}]
    writer.writerow(fields)

    # Write sample row
    sample = [{% for field in model.fields %}{% if field.name not in ['id', 'created_at', 'updated_at'] and 'c' in field.permissions %}{% if field.ui_type == 'int' %}0{% elif field.ui_type == 'float' %}0.0{% elif field.ui_type == 'bool' %}True{% else %}"sample"{% endif %}{% if not loop.last %}, {% endif %}{% endif %}{% endfor %}]
    writer.writerow(sample)

    output.seek(0)

    return StreamingResponse(
        io.BytesIO(output.getvalue().encode("utf-8-sig")),
        media_type="text/csv",
        headers={"Content-Disposition": f"attachment; filename={{ model.module_name }}_template.csv"}
    )
{% endif %}
{% endif %}
