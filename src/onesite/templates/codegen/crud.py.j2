# M2M Relationship CRUD functions
{% for m2m in model.m2m_fields %}
async def get_{{ m2m.target_endpoint }}(session: AsyncSession, {{ model.lower_name }}_id: int) -> List[int]:
    """Get list of {{ m2m.target_model }} IDs related to {{ model.name }}."""
    statement = select({{ m2m.link_model }}.{{ m2m.target_fk_field }}).where(
        {{ m2m.link_model }}.{{ m2m.source_fk_field }} == {{ model.lower_name }}_id
    )
    result = await session.exec(statement)
    return list(result.all())


async def count_{{ m2m.target_endpoint }}(session: AsyncSession, {{ model.lower_name }}_id: int) -> int:
    """Count {{ m2m.target_model }}s related to {{ model.name }}."""
    statement = select(func.count()).select_from({{ m2m.link_model }}).where(
        {{ m2m.link_model }}.{{ m2m.source_fk_field }} == {{ model.lower_name }}_id
    )
    result = await session.exec(statement)
    return result.one()

{% if m2m.order_field %}
async def get_{{ m2m.target_endpoint }}_with_order(
    session: AsyncSession,
    {{ model.lower_name }}_id: int,
    page: int = 1,
    size: int = 50,
) -> tuple[List[tuple], int]:
    """Get {{ m2m.target_model }}s with order field. Returns (items, total)."""
    skip = (page - 1) * size
    
    # Count total
    total = await count_{{ m2m.target_endpoint }}(session, {{ model.lower_name }}_id)
    
    if total == 0:
        return [], 0
    
    # Query with join
    from app.models.{{ m2m.target_source_module }} import {{ m2m.target_model }}
    statement = (
        select({{ m2m.target_model }}.id, {{ m2m.target_model }}.{{ m2m.label_field }}, {{ m2m.link_model }}.{{ m2m.order_field }})
        .join({{ m2m.link_model }}, {{ m2m.link_model }}.{{ m2m.target_fk_field }} == {{ m2m.target_model }}.id)
        .where({{ m2m.link_model }}.{{ m2m.source_fk_field }} == {{ model.lower_name }}_id)
        .order_by({{ m2m.link_model }}.{{ m2m.order_field }})
        .offset(skip)
        .limit(size)
    )
    result = await session.exec(statement)
    rows = result.all()
    
    return rows, total
{% endif %}
{% endfor %}
{% endif %}

