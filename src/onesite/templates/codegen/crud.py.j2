{% if model.union_key %}
# Union Key (Composite Key) lookup
async def get_by_{{ model.union_key | join('_') }}(
    session: AsyncSession,
    {% for key_field in model.union_key %}
    {{ key_field }}: {% if key_field.endswith('_id') %}int{% else %}str{% endif %}{% if not loop.last %},
    {% endif %}
    {% endfor %}
) -> Optional[{{ model.name }}]:
    """Get {{ model.name }} by composite key: {{ model.union_key | join(', ') }}."""
    statement = select({{ model.name }}).where(
        {% for key_field in model.union_key %}
        {{ model.name }}.{{ key_field }} == {{ key_field }}{% if not loop.last %},
        {% endif %}
        {% endfor %}
    )
    result = await session.exec(statement)
    return result.first()
{% endif %}
