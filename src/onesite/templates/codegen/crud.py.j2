async def get(session: AsyncSession, id: int) -> Optional[{{ model.name }}]:
    return await session.get({{ model.name }}, id)


{% if model.fields | selectattr('is_unique') | list %}
async def check_unique_field(
    session: AsyncSession,
    field_name: str,
    value: Any,
    exclude_id: Optional[int] = None,
) -> bool:
    """
    Check if a field value is unique.
    Returns True if unique (no conflict), False if duplicate exists.
    """
    statement = select({{ model.name }}).where(getattr({{ model.name }}, field_name) == value)
    if exclude_id is not None:
        statement = statement.where({{ model.name }}.id != exclude_id)
    result = await session.exec(statement)
    return result.first() is None
{% endif %}

{% if model.importable and model.import_key %}
async def get_by_{{ model.import_key }}(
    session: AsyncSession,
    value: Any,
) -> Optional[{{ model.name }}]:
    """
    Get {{ model.name }} by {{ model.import_key }} value.
    Used for import upsert logic.
    """
    statement = select({{ model.name }}).where(getattr({{ model.name }}, "{{ model.import_key }}") == value)
    result = await session.exec(statement)
    return result.first()
{% endif %}


def _apply_filters(
    statement,
    *,
    {% for field in model.fields %}
    {% if field.is_search_field and field.name != 'id' %}
    {% if field.ui_type == 'bool' %}
    {{ field.name }}: Optional[bool] = None,
    {% elif field.ui_type == 'datetime' %}
    {{ field.name }}_from: Optional[datetime] = None,
    {{ field.name }}_to: Optional[datetime] = None,
    {% elif field.ui_type == 'time' %}
    {{ field.name }}: Optional[time] = None,
    {% elif field.is_enum %}
    {{ field.name }}: Optional[str] = None,
    {% elif field.ui_type == 'str' %}
    {{ field.name }}: Optional[str] = None,
    {% endif %}
    {% endif %}
    {% endfor %}
    {% for fk in model.foreign_keys %}
    {{ fk.name }}: Optional[int] = None,
    {% endfor %}
):
    """Apply search and filter conditions to statement. Shared by get_multi and count."""
    # Apply per-field filters (configured via site_props.is_search_field)
    {% for field in model.fields %}
    {% if field.is_search_field and field.name != 'id' %}
    {% if field.ui_type == 'bool' %}
    if {{ field.name }} is not None:
        statement = statement.where({{ model.name }}.{{ field.name }} == {{ field.name }})
    {% elif field.ui_type == 'datetime' %}
    if {{ field.name }}_from is not None:
        statement = statement.where({{ model.name }}.{{ field.name }} >= {{ field.name }}_from)
    if {{ field.name }}_to is not None:
        statement = statement.where({{ model.name }}.{{ field.name }} <= {{ field.name }}_to)
    {% elif field.ui_type == 'time' %}
    if {{ field.name }} is not None:
        statement = statement.where({{ model.name }}.{{ field.name }} == {{ field.name }})
    {% elif field.is_enum %}
    if {{ field.name }}:
        statement = statement.where({{ model.name }}.{{ field.name }} == {{ field.name }})
    {% elif field.ui_type == 'str' %}
    if {{ field.name }}:
        statement = statement.where(col({{ model.name }}.{{ field.name }}).ilike("%" + {{ field.name }} + "%"))
    {% endif %}
    {% endif %}
    {% endfor %}

    # Apply foreign key filters
    {% for fk in model.foreign_keys %}
    if {{ fk.name }}:
        statement = statement.where({{ model.name }}.{{ fk.name }} == {{ fk.name }})
    {% endfor %}
    
    return statement


async def get_multi(
    session: AsyncSession,
    *,
    page: int = 1,
    size: int = 20,
    {% for field in model.fields %}
    {% if field.is_search_field and field.name != 'id' %}
    {% if field.ui_type == 'bool' %}
    {{ field.name }}: Optional[bool] = None,
    {% elif field.ui_type == 'datetime' %}
    {{ field.name }}_from: Optional[datetime] = None,
    {{ field.name }}_to: Optional[datetime] = None,
    {% elif field.ui_type == 'time' %}
    {{ field.name }}: Optional[time] = None,
    {% elif field.is_enum %}
    {{ field.name }}: Optional[str] = None,
    {% elif field.ui_type == 'str' %}
    {{ field.name }}: Optional[str] = None,
    {% endif %}
    {% endif %}
    {% endfor %}
    {% for fk in model.foreign_keys %}
    {{ fk.name }}: Optional[int] = None,
    {% endfor %}
) -> List[{{ model.name }}]:
    """
    Get list of objects with optional search and filter support.
    When size=-1, returns all matching records without pagination.
    Returns only the list of objects; use count() for total.
    """
    statement = select({{ model.name }})
    statement = _apply_filters(
        statement,
        {% for field in model.fields %}
        {% if field.is_search_field and field.name != 'id' %}
        {% if field.ui_type == 'bool' %}
        {{ field.name }}={{ field.name }},
        {% elif field.ui_type == 'datetime' %}
        {{ field.name }}_from={{ field.name }}_from,
        {{ field.name }}_to={{ field.name }}_to,
        {% elif field.is_enum %}
        {{ field.name }}={{ field.name }},
        {% elif field.ui_type == 'str' %}
        {{ field.name }}={{ field.name }},
        {% endif %}
        {% endif %}
        {% endfor %}
        {% for fk in model.foreign_keys %}
        {{ fk.name }}={{ fk.name }},
        {% endfor %}
    )
    
    # Apply pagination (skip if size == -1, meaning get all)
    if size != -1:
        skip = (page - 1) * size
        statement = statement.offset(skip).limit(size)
    
    result = await session.exec(statement)
    return list(result.all())


async def get_multi_with_fk_labels(
    session: AsyncSession,
    *,
    page: int = 1,
    size: int = 20,
    {% for field in model.fields %}
    {% if field.is_search_field and field.name != 'id' %}
    {% if field.ui_type == 'bool' %}
    {{ field.name }}: Optional[bool] = None,
    {% elif field.ui_type == 'datetime' %}
    {{ field.name }}_from: Optional[datetime] = None,
    {{ field.name }}_to: Optional[datetime] = None,
    {% elif field.ui_type == 'time' %}
    {{ field.name }}: Optional[time] = None,
    {% elif field.is_enum %}
    {{ field.name }}: Optional[str] = None,
    {% elif field.ui_type == 'str' %}
    {{ field.name }}: Optional[str] = None,
    {% endif %}
    {% endif %}
    {% endfor %}
    {% for fk in model.foreign_keys %}
    {{ fk.name }}: Optional[int] = None,
    {% endfor %}
) -> List[Dict[str, Any]]:
    """
    Get list of objects with FK label fields enriched.
    Returns list of dicts with original fields plus {fk_name}_label for each FK.
    """
    # Get base items
    items = await get_multi(
        session,
        page=page,
        size=size,
        {% for field in model.fields %}
        {% if field.is_search_field and field.name != 'id' %}
        {% if field.ui_type == 'bool' %}
        {{ field.name }}={{ field.name }},
        {% elif field.ui_type == 'datetime' %}
        {{ field.name }}_from={{ field.name }}_from,
        {{ field.name }}_to={{ field.name }}_to,
        {% elif field.is_enum %}
        {{ field.name }}={{ field.name }},
        {% elif field.ui_type == 'str' %}
        {{ field.name }}={{ field.name }},
        {% endif %}
        {% endif %}
        {% endfor %}
        {% for fk in model.foreign_keys %}
        {{ fk.name }}={{ fk.name }},
        {% endfor %}
    )
    
    if not items:
        return []
    
    {% if model.foreign_keys %}
    # Collect unique FK IDs for batch fetch
    {% for fk in model.foreign_keys %}
    {{ fk.name }}_ids = list(set(getattr(item, "{{ fk.name }}") for item in items if getattr(item, "{{ fk.name }}") is not None))
    {% endfor %}
    
    # Batch fetch FK targets
    {% for fk in model.foreign_keys %}
    {{ fk.name }}_map = {}
    if {{ fk.name }}_ids:
        from app.models.{{ fk.target_service }} import {{ fk.target_model }}
        stmt = select({{ fk.target_model }}).where({{ fk.target_model }}.id.in_({{ fk.name }}_ids))
        result = await session.exec(stmt)
        for obj in result.all():
            {{ fk.name }}_map[obj.id] = getattr(obj, "{{ fk.label_field }}", None) or str(obj.id)
    {% endfor %}
    
    # Enrich items with labels
    enriched = []
    for item in items:
        item_dict = item.model_dump()
        {% for fk in model.foreign_keys %}
        fk_id = getattr(item, "{{ fk.name }}", None)
        item_dict["{{ fk.name }}_label"] = {{ fk.name }}_map.get(fk_id) if fk_id else None
        {% endfor %}
        enriched.append(item_dict)
    
    return enriched
    {% else %}
    # No FKs, just convert to dicts
    return [item.model_dump() for item in items]
    {% endif %}


async def count(
    session: AsyncSession,
    *,
    {% for field in model.fields %}
    {% if field.is_search_field and field.name != 'id' %}
    {% if field.ui_type == 'bool' %}
    {{ field.name }}: Optional[bool] = None,
    {% elif field.ui_type == 'datetime' %}
    {{ field.name }}_from: Optional[datetime] = None,
    {{ field.name }}_to: Optional[datetime] = None,
    {% elif field.ui_type == 'time' %}
    {{ field.name }}: Optional[time] = None,
    {% elif field.is_enum %}
    {{ field.name }}: Optional[str] = None,
    {% elif field.ui_type == 'str' %}
    {{ field.name }}: Optional[str] = None,
    {% endif %}
    {% endif %}
    {% endfor %}
    {% for fk in model.foreign_keys %}
    {{ fk.name }}: Optional[int] = None,
    {% endfor %}
) -> int:
    """
    Count total matching records with same filter conditions as get_multi.
    """
    statement = select(func.count()).select_from({{ model.name }})
    statement = _apply_filters(
        statement,
        {% for field in model.fields %}
        {% if field.is_search_field and field.name != 'id' %}
        {% if field.ui_type == 'bool' %}
        {{ field.name }}={{ field.name }},
        {% elif field.ui_type == 'datetime' %}
        {{ field.name }}_from={{ field.name }}_from,
        {{ field.name }}_to={{ field.name }}_to,
        {% elif field.is_enum %}
        {{ field.name }}={{ field.name }},
        {% elif field.ui_type == 'str' %}
        {{ field.name }}={{ field.name }},
        {% endif %}
        {% endif %}
        {% endfor %}
        {% for fk in model.foreign_keys %}
        {{ fk.name }}={{ fk.name }},
        {% endfor %}
    )
    
    result = await session.exec(statement)
    return result.one()

async def create(session: AsyncSession, obj_in: {{ model.name }}Create) -> {{ model.name }}:
    # Note: validation should happen before, here we assume obj_in is valid pydantic model
    
    # Handle M2M fields
    {% if model.m2m_fields %}
    m2m_data = {}
    {% for m2m in model.m2m_fields %}
    if hasattr(obj_in, "{{ m2m.name }}"):
        m2m_data["{{ m2m.name }}"] = getattr(obj_in, "{{ m2m.name }}")
        delattr(obj_in, "{{ m2m.name }}")
    {% endfor %}
    {% endif %}

    # Convert to dict to handle nested Pydantic models in JSON fields
    obj_dict = obj_in.dict()
    db_obj = {{ model.name }}(**obj_dict)
    
    session.add(db_obj)
    await session.commit()
    await session.refresh(db_obj)
    
    {% if model.m2m_fields %}
    # Insert M2M relations
    {% for m2m in model.m2m_fields %}
    if m2m_data.get("{{ m2m.name }}") is not None:
        for idx, target_id in enumerate(m2m_data["{{ m2m.name }}"], start=1):
            link = {{ m2m.link_model }}(
                {{ m2m.source_fk_field }}=db_obj.id,
                {{ m2m.target_fk_field }}=target_id
                {% if m2m.order_field %}
                , {{ m2m.order_field }}=idx
                {% endif %}
            )
            session.add(link)
    {% endfor %}
    await session.commit()
    await session.refresh(db_obj)
    {% endif %}
    
    return db_obj

async def update(session: AsyncSession, db_obj: {{ model.name }}, obj_in: {{ model.name }}Update) -> {{ model.name }}:
    obj_data = obj_in.dict(exclude_unset=True)
    
    {% if model.m2m_fields %}
    # Handle M2M updates
    {% for m2m in model.m2m_fields %}
    if "{{ m2m.name }}" in obj_data:
        new_ids = obj_data.pop("{{ m2m.name }}")
        if new_ids is not None:
            # 1. Clear existing relations
            # This is a naive implementation (delete all and re-insert). 
            # Better would be to calculate diff.
            statement = select({{ m2m.link_model }}).where({{ m2m.link_model }}.{{ m2m.source_fk_field }} == db_obj.id)
            result = await session.exec(statement)
            existing_links = result.all()
            for link in existing_links:
                await session.delete(link)
            
            # 2. Insert new relations
            for idx, target_id in enumerate(new_ids, start=1):
                link = {{ m2m.link_model }}(
                    {{ m2m.source_fk_field }}=db_obj.id,
                    {{ m2m.target_fk_field }}=target_id
                    {% if m2m.order_field %}
                    , {{ m2m.order_field }}=idx
                    {% endif %}
                )
                session.add(link)
    {% endfor %}
    {% endif %}
    
    for key, value in obj_data.items():
        setattr(db_obj, key, value)
    session.add(db_obj)
    await session.commit()
    await session.refresh(db_obj)
    return db_obj

async def delete(session: AsyncSession, id: int) -> int:
    db_obj = await session.get({{ model.name }}, id)
    await session.delete(db_obj)
    await session.commit()
    return db_obj.id

{% if model.is_notification_table %}
async def mark_all_read_by_user(session: AsyncSession, user_id: int) -> int:
    """
    Mark all unread notifications as read for a specific user.
    Returns the number of notifications updated.
    """
    from sqlmodel import update

    statement = (
        update({{ model.name }})
        .where({{ model.name }}.user_id == user_id)
        .where({{ model.name }}.is_read == False)
        .values(is_read=True)
    )
    result = await session.exec(statement)
    await session.commit()
    return result.rowcount
{% endif %}

