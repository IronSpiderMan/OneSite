import { create } from 'zustand';
import { {{ model.name }}, get{{ model.name }}s, get{{ model.name }}, create{{ model.name }}, update{{ model.name }}, delete{{ model.name }}, bulkDelete{{ model.name }} } from '../services/{{ model.module_name }}';

interface {{ model.name }}State {
    data: {{ model.name }}[];
    total: number;
    page: number;
    size: number;
    loading: boolean;
    currentItem: {{ model.name }} | null;
    query: string;
    filters: Record<string, any>;
    fetchData: (page?: number, size?: number, query?: string, filters?: Record<string, any>) => Promise<void>;
    fetchItem: (id: number) => Promise<{{ model.name }} | null>;
    createItem: (item: any) => Promise<void>;
    updateItem: (id: number, item: any) => Promise<void>;
    deleteItem: (id: number) => Promise<void>;
    bulkDeleteItem: (ids: number[]) => Promise<void>;
}

export const use{{ model.name }}Store = create<{{ model.name }}State>((set, get) => ({
    data: [],
    total: 0,
    page: 1,
    size: 20,
    loading: false,
    currentItem: null,
    query: "",
    filters: {},
    fetchData: async (page = 1, size = 20, query?: string, filters?: Record<string, any>) => {
        set({ loading: true });
        try {
            const q = query !== undefined ? query : get().query;
            const f = filters !== undefined ? filters : get().filters;
            const result = await get{{ model.name }}s(page, size, q || undefined, f);
            if (result && Array.isArray(result.items)) {
                set({ 
                    data: result.items,
                    total: result.total,
                    page: result.page,
                    size: result.size,
                    query: q,
                    filters: f
                });
            } else {
                console.error("Expected paginated response but got:", result);
                set({ data: [], total: 0 });
            }
        } catch (error) {
            console.error(error);
            set({ data: [], total: 0 });
        } finally {
            set({ loading: false });
        }
    },
    fetchItem: async (id: number) => {
        set({ loading: true });
        try {
            const result = await get{{ model.name }}(id);
            set({ currentItem: result });
            return result;
        } catch (error) {
            console.error(error);
            set({ currentItem: null });
            return null;
        } finally {
            set({ loading: false });
        }
    },
    createItem: async (item: any) => {
        try {
            await create{{ model.name }}(item);
            const { page, size, query, filters } = get();
            await get().fetchData(page, size, query, filters);
        } catch (error) {
            console.error(error);
            throw error;
        }
    },
    updateItem: async (id: number, item: any) => {
        try {
            await update{{ model.name }}(id, item);
            const { page, size, query, filters } = get();
            await get().fetchData(page, size, query, filters);
        } catch (error) {
            console.error(error);
            throw error;
        }
    },
    deleteItem: async (id: number) => {
        try {
            await delete{{ model.name }}(id);
            const { page, size, query, filters } = get();
            await get().fetchData(page, size, query, filters);
        } catch (error) {
            console.error(error);
            throw error;
        }
    },
    bulkDeleteItem: async (ids: number[]) => {
        try {
            await bulkDelete{{ model.name }}(ids);
            const { page, size, query, filters } = get();
            await get().fetchData(page, size, query, filters);
        } catch (error) {
            console.error(error);
            throw error;
        }
    },
}));
